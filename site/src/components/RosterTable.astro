---
import { fmtEra, fmtRate3 } from '../lib/format';
import { getDisplayablePlayers, getLeagueByKey } from '../lib/data';
import type { Player, Slider } from '../lib/data';
import Headshot from './Headshot.astro';
import PercentileChip from './PercentileChip.astro';

const assigned = getDisplayablePlayers();

function sliderPct(p: Player, side: 'hitting' | 'pitching', metric: string): number | null {
  const s: Slider | undefined = p[side]?.sliders?.find((x) => x.metric === metric);
  return s ? s.percentile : null;
}
// The table leads with the story: best percentile first (FanGraphs-style
// opinionated default). The matching th below is marked data-dir/aria-sort
// so the client script and screen readers see the same state.
const byPct = (side: 'hitting' | 'pitching', metric: string) => (a: Player, b: Player) =>
  (sliderPct(b, side, metric) ?? -1) - (sliderPct(a, side, metric) ?? -1);
const hitters = assigned.filter((p) => p.hitting).sort(byPct('hitting', 'ops'));
const pitchers = assigned.filter((p) => p.pitching).sort(byPct('pitching', 'era'));
const statted = [...hitters, ...pitchers];
const leagues = [...new Set(statted.map((p) => p.summer.leagueKey!))]
  .map((k) => getLeagueByKey(k)!)
  .filter(Boolean);

function leagueAbbrev(p: Player): string {
  return getLeagueByKey(p.summer.leagueKey)?.abbrev ?? '';
}
function leagueName(p: Player): string {
  return getLeagueByKey(p.summer.leagueKey)?.name ?? '';
}
---
<div class="card shell">
  <div class="toolbar">
  <div class="tabs" role="tablist">
    <button class="tab active" data-target="hitters" type="button" role="tab"
      aria-selected="true" aria-controls="hitters">Hitters</button>
    <button class="tab" data-target="pitchers" type="button" role="tab"
      aria-selected="false" aria-controls="pitchers">Pitchers</button>
  </div>
  <div class="filters">
    <input type="search" id="player-search" placeholder="Find a player…"
      aria-label="Filter players by name or team" autocomplete="off" />
    <select id="league-filter" aria-label="Filter by league">
      <option value="">All Leagues</option>
      {leagues.map((l) => <option value={l.key}>{l.name}</option>)}
    </select>
  </div>
  </div>

  <div class="panel" id="hitters" role="tabpanel">
  {hitters.length === 0 ? (
    <p class="none">No GT hitters with summer stats yet.</p>
  ) : (
    <table data-sortable>
      <thead>
        <tr>
          <th data-key="name" tabindex="0" scope="col">Player</th>
          <th data-key="pos" tabindex="0" scope="col" class="opt">Pos</th>
          <th data-key="cls" tabindex="0" scope="col" class="opt">Class</th>
          <th data-key="lg" tabindex="0" scope="col" class="opt">League</th>
          <th data-key="g" data-numeric tabindex="0" scope="col" class="opt">G</th>
          <th data-key="ab" data-numeric tabindex="0" scope="col" class="opt">AB</th>
          <th data-key="avg" data-numeric tabindex="0" scope="col">AVG</th>
          <th data-key="obp" data-numeric tabindex="0" scope="col">OBP</th>
          <th data-key="slg" data-numeric tabindex="0" scope="col">SLG</th>
          <th data-key="ops" data-numeric tabindex="0" scope="col">OPS</th>
          <th data-key="hr" data-numeric tabindex="0" scope="col">HR</th>
          <th data-key="rbi" data-numeric tabindex="0" scope="col">RBI</th>
          <th data-key="sb" data-numeric tabindex="0" scope="col">SB</th>
          <th data-key="pct" data-numeric data-dir="desc" aria-sort="descending" tabindex="0" scope="col">OPS %ile</th>
        </tr>
      </thead>
      <tbody>
        {hitters.map((p) => {
          const c = p.hitting!.counting;
          const r = p.hitting!.rates;
          const pct = sliderPct(p, 'hitting', 'ops');
          return (
            <tr data-league={p.summer.leagueKey}>
              <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={32} /><span class="who"><span class="pname">{p.name} <span class="mchip"><PercentileChip percentile={pct} /></span></span><span class="pteam">{p.summer.team}</span></span></a></td>
              <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
              <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
              <td data-v={leagueAbbrev(p)} class="opt"><abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></td>
              <td data-v={c.g} class="opt">{c.g}</td>
              <td data-v={c.ab} class="opt">{c.ab}</td>
              <td data-v={r.avg ?? '—'}>{fmtRate3(r.avg)}</td>
              <td data-v={r.obp ?? '—'}>{fmtRate3(r.obp)}</td>
              <td data-v={r.slg ?? '—'}>{fmtRate3(r.slg)}</td>
              <td data-v={r.ops ?? '—'} class="strong">{fmtRate3(r.ops)}</td>
              <td data-v={c.hr}>{c.hr}</td>
              <td data-v={c.rbi}>{c.rbi}</td>
              <td data-v={c.sb}>{c.sb}</td>
              <td data-v={pct ?? '—'}><PercentileChip percentile={pct} /></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  )}
</div>

<div class="panel" id="pitchers" role="tabpanel" hidden>

  {pitchers.length === 0 ? (
    <p class="none">No GT pitchers with summer stats yet.</p>
  ) : (
    <table data-sortable>
      <thead>
        <tr>
          <th data-key="name" tabindex="0" scope="col">Player</th>
          <th data-key="pos" tabindex="0" scope="col" class="opt">Pos</th>
          <th data-key="cls" tabindex="0" scope="col" class="opt">Class</th>
          <th data-key="lg" tabindex="0" scope="col" class="opt">League</th>
          <th data-key="g" data-numeric tabindex="0" scope="col" class="opt">G</th>
          <th data-key="gs" data-numeric tabindex="0" scope="col" class="opt">GS</th>
          <th data-key="ip" data-numeric tabindex="0" scope="col">IP</th>
          <th data-key="era" data-numeric tabindex="0" scope="col">ERA</th>
          <th data-key="whip" data-numeric tabindex="0" scope="col">WHIP</th>
          <th data-key="k" data-numeric tabindex="0" scope="col">K</th>
          <th data-key="bb" data-numeric tabindex="0" scope="col">BB</th>
          <th data-key="sv" data-numeric tabindex="0" scope="col">SV</th>
          <th data-key="pct" data-numeric data-dir="desc" aria-sort="descending" tabindex="0" scope="col">ERA %ile</th>
        </tr>
      </thead>
      <tbody>
        {pitchers.map((p) => {
          const c = p.pitching!.counting;
          const r = p.pitching!.rates;
          const pct = sliderPct(p, 'pitching', 'era');
          return (
            <tr data-league={p.summer.leagueKey}>
              <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={32} /><span class="who"><span class="pname">{p.name} <span class="mchip"><PercentileChip percentile={pct} /></span></span><span class="pteam">{p.summer.team}</span></span></a></td>
              <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
              <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
              <td data-v={leagueAbbrev(p)} class="opt"><abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></td>
              <td data-v={c.g} class="opt">{c.g}</td>
              <td data-v={c.gs} class="opt">{c.gs}</td>
              <td data-v={c.ip}>{c.ip}</td>
              <td data-v={r.era ?? '—'} class="strong">{fmtEra(r.era)}</td>
              <td data-v={r.whip ?? '—'}>{fmtEra(r.whip)}</td>
              <td data-v={c.k}>{c.k}</td>
              <td data-v={c.bb}>{c.bb}</td>
              <td data-v={c.sv}>{c.sv}</td>
              <td data-v={pct ?? '—'}><PercentileChip percentile={pct} /></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  )}
</div>
</div>

<script>
  import { compareCells } from '../lib/tableSort';
  import type { SortDir } from '../lib/tableSort';
  import { parseViewState, serializeViewState } from '../lib/viewState';
  import type { Tab, ViewState } from '../lib/viewState';

  const filter = document.getElementById('league-filter') as HTMLSelectElement;
  const search = document.getElementById('player-search') as HTMLInputElement;

  function activateTab(tab: HTMLButtonElement) {
    document.querySelectorAll('.tab').forEach((t) => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');
    document.getElementById('hitters')!.toggleAttribute('hidden', tab.dataset.target !== 'hitters');
    document.getElementById('pitchers')!.toggleAttribute('hidden', tab.dataset.target !== 'pitchers');
  }

  function applyLeagueFilter() {
    const q = search.value.trim().toLowerCase();
    document.querySelectorAll<HTMLTableRowElement>('tr[data-league]').forEach((row) => {
      const leagueOk = !filter.value || row.dataset.league === filter.value;
      const nameOk = !q || (row.cells[0].textContent ?? '').toLowerCase().includes(q);
      row.style.display = leagueOk && nameOk ? '' : 'none';
    });
  }

  search.addEventListener('input', applyLeagueFilter);
  search.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      search.value = '';
      applyLeagueFilter();
    }
  });

  function applySort(table: HTMLTableElement, th: HTMLTableCellElement, dir: SortDir) {
    const idx = th.cellIndex;
    table.querySelectorAll('th').forEach((h) => {
      delete h.dataset.dir;
      h.removeAttribute('aria-sort');
    });
    th.dataset.dir = dir;
    th.setAttribute('aria-sort', dir === 'asc' ? 'ascending' : 'descending');
    const numeric = th.hasAttribute('data-numeric');
    const body = table.tBodies[0];
    [...body.rows]
      .sort((a, b) => compareCells(
        a.cells[idx].dataset.v ?? '', b.cells[idx].dataset.v ?? '', numeric, dir))
      .forEach((r) => body.appendChild(r));
  }

  function currentState(): ViewState {
    const active = document.querySelector<HTMLButtonElement>('.tab.active');
    const tab: Tab = active?.dataset.target === 'pitchers' ? 'pitchers' : 'hitters';
    const sorted = document.querySelector<HTMLTableCellElement>(`#${tab} th[data-dir]`);
    return {
      tab,
      league: filter.value,
      sort: sorted
        ? { key: sorted.dataset.key!, dir: sorted.dataset.dir === 'desc' ? 'desc' : 'asc' }
        : null,
    };
  }

  function syncUrl() {
    const qs = serializeViewState(currentState());
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  document.querySelectorAll<HTMLButtonElement>('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      activateTab(tab);
      syncUrl();
    });
  });

  filter.addEventListener('change', () => {
    applyLeagueFilter();
    syncUrl();
  });

  document.querySelectorAll<HTMLTableElement>('table[data-sortable]').forEach((table) => {
    table.querySelectorAll<HTMLTableCellElement>('th[data-key]').forEach((th) => {
      th.addEventListener('click', () => {
        applySort(table, th, th.dataset.dir === 'asc' ? 'desc' : 'asc');
        syncUrl();
      });
      // Headers are focusable (tabindex in markup); Enter/Space must sort too.
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          th.click();
        }
      });
    });
  });

  // Edge shadow on the sticky player column while the table is scrolled.
  document.querySelectorAll<HTMLElement>('[role="tabpanel"]').forEach((panel) => {
    const update = () => panel.toggleAttribute('data-scrolled', panel.scrollLeft > 2);
    panel.addEventListener('scroll', update, { passive: true });
    update();
  });

  // Restore view state carried in the URL (e.g. returning via browser back from a player page),
  // driving the same code paths the click/change handlers use. Unknown values are ignored.
  const restored = parseViewState(location.search);
  if (restored.tab === 'pitchers') {
    const btn = document.querySelector<HTMLButtonElement>('.tab[data-target="pitchers"]');
    if (btn) activateTab(btn);
  }
  if (restored.league && [...filter.options].some((o) => o.value === restored.league)) {
    filter.value = restored.league;
    applyLeagueFilter();
  }
  if (restored.sort) {
    const table = document.querySelector<HTMLTableElement>(`#${restored.tab} table[data-sortable]`);
    const th = table?.querySelector<HTMLTableCellElement>(`th[data-key="${CSS.escape(restored.sort.key)}"]`);
    if (table && th) applySort(table, th, restored.sort.dir);
  }
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line-soft);
  }
  .tabs { display: flex; gap: 6px; }
  .tab {
    border: none;
    background: var(--well);
    color: var(--text); /* --text-mut on --well is 4.0:1 — fails AA */
    font-size: 12px;
    font-weight: 700;
    border-radius: 14px;
    padding: 5px 14px;
    cursor: pointer;
  }
  .tab:hover:not(.active) { background: var(--line); color: var(--text); }
  .tab.active { background: var(--navy); color: var(--on-navy); }
  .filters { display: flex; gap: 8px; flex-wrap: wrap; }
  select,
  input[type='search'] {
    font-size: 12px;
    padding: 5px 8px;
    border-radius: 6px;
    border: 1px solid var(--line);
    background: var(--card);
  }
  input[type='search'] { width: 150px; }
  select:hover,
  input[type='search']:hover { border-color: var(--text-mut); }
  .panel { overflow-x: auto; }
  table { font-size: 12.5px; }
  th {
    cursor: pointer;
    user-select: none;
    text-align: left;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-mut);
    font-weight: 700;
    padding: 8px;
    border-bottom: 2px solid var(--gold);
    white-space: nowrap;
  }
  th[data-key]::after { content: ' ↕'; opacity: 0; }
  th[data-key]:hover::after,
  th[data-key]:focus-visible::after { opacity: 0.55; }
  th[data-dir='asc']::after { content: ' ↑'; opacity: 1; }
  th[data-dir='desc']::after { content: ' ↓'; opacity: 1; }
  td { padding: 10px 8px; border-bottom: 1px solid var(--line-soft); white-space: nowrap; }
  th:first-child, td:first-child { padding-left: 14px; }
  th:last-child, td:last-child { padding-right: 14px; }
  td:first-child { background: var(--card); }
  tbody tr:hover td { background: var(--line-soft); }
  td a { display: inline-flex; align-items: center; gap: 7px; font-weight: 700; }
  .who {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .pteam {
    color: var(--text-mut);
    font-weight: 400;
    font-size: 11px;
  }
  .strong { font-weight: 800; }
  abbr { text-decoration: none; cursor: help; }
  .mchip { display: none; }
  .none { padding: 16px; color: var(--text-mut); font-size: 13px; }

  @media (max-width: 700px) {
    th:first-child, td:first-child {
      position: sticky;
      left: 0;
      z-index: 1;
    }
    th:first-child { background: var(--card); }
    [data-scrolled] th:first-child,
    [data-scrolled] td:first-child {
      box-shadow: 8px 0 8px -8px rgba(0, 0, 0, 0.28);
    }
  }
  @media (max-width: 560px) {
    .opt { display: none; }
    /* The chip moves into the player cell, so the trailing %ile column
       (and its horizontal scroll cost) goes away on phones. */
    .mchip { display: inline-flex; vertical-align: 1px; }
    th[data-key='pct'], td:last-child { display: none; }
  }
  @media (prefers-reduced-motion: no-preference) {
    td { transition: background-color var(--t-fast) var(--ease-out); }
    th[data-key]::after { transition: opacity var(--t-fast) var(--ease-out); }
    .tab { transition: background-color var(--t-fast) var(--ease-out), color var(--t-fast) var(--ease-out); }
  }
</style>
