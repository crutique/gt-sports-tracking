---
import { fmtDate, fmtEra, fmtRate3 } from '../lib/format';
import { getDisplayablePlayers, getLeagueByKey, provenanceLabel } from '../lib/data';
import type { Player, Slider } from '../lib/data';
import { DEADLINE_LABEL, getDraft, isDeadlinePending } from '../lib/draft';
import Headshot from './Headshot.astro';
import PercentileBar from './PercentileBar.astro';
import PercentileChip from './PercentileChip.astro';
import ProvenanceTag from './ProvenanceTag.astro';

const assigned = getDisplayablePlayers();

// Provenance lives on the portrait: the + badge marks players new to GT and
// its tooltip says where they're from. Only the drafted-but-unsigned limbo
// keeps a visible tag — that deadline is a warning, not a footnote.
const draftLimbo = new Set(
  getDraft().players
    .filter((d) => d.gtRole === 'signee' && d.status === 'unsigned' && d.slug)
    .map((d) => d.slug as string),
);
function provProps(p: Player) {
  if (draftLimbo.has(p.slug))
    return { kind: 'drafted', deadline: isDeadlinePending() ? DEADLINE_LABEL : null } as const;
  return null;
}
const isIncoming = (p: Player) => p.gtStatus !== 'returning' && !draftLimbo.has(p.slug);

function sliderPct(p: Player, side: 'hitting' | 'pitching', metric: string): number | null {
  const s: Slider | undefined = p[side]?.sliders?.find((x) => x.metric === metric);
  return s ? s.percentile : null;
}
// The table leads with the story: best percentile first (FanGraphs-style
// opinionated default). The matching th below is marked data-dir/aria-sort
// so the client script and screen readers see the same state.
const byPct = (side: 'hitting' | 'pitching', metric: string) => (a: Player, b: Player) =>
  (sliderPct(b, side, metric) ?? -1) - (sliderPct(a, side, metric) ?? -1);

// Rankings only mean something with a real sample behind them — sub-threshold
// players keep their rows but sit in a separate band below the line.
// One qualifying definition site-wide: the pipeline's per-team-game bar
// (2.0 PA / 0.5 IP), carried on each block as `qualified` (undefined = old data
// -> treat as qualified).
const isQual = (b: { qualified?: boolean } | null | undefined) => b?.qualified !== false;

const hittersAll = assigned.filter((p) => p.hitting).sort(byPct('hitting', 'ops'));
const hitters = hittersAll.filter((p) => isQual(p.hitting));
const hittersSub = hittersAll.filter((p) => !isQual(p.hitting));
const pitchersAll = assigned.filter((p) => p.pitching).sort(byPct('pitching', 'era'));
const pitchers = pitchersAll.filter((p) => isQual(p.pitching));
const pitchersSub = pitchersAll.filter((p) => !isQual(p.pitching));

const statted = [...hittersAll, ...pitchersAll];
const leagues = [...new Set(statted.map((p) => p.summer.leagueKey!))]
  .map((k) => getLeagueByKey(k)!)
  .filter(Boolean);

function leagueAbbrev(p: Player): string {
  return getLeagueByKey(p.summer.leagueKey)?.abbrev ?? '';
}
function leagueName(p: Player): string {
  return getLeagueByKey(p.summer.leagueKey)?.name ?? '';
}
function searchKey(p: Player): string {
  const lg = getLeagueByKey(p.summer.leagueKey);
  return `${p.name} ${p.summer.team ?? ''} ${lg?.name ?? ''} ${lg?.abbrev ?? ''} ${p.fromSchool ?? ''} ${p.fromShort ?? ''}`.toLowerCase();
}

const statsThrough = assigned.map((p) => p.asOf).filter(Boolean).sort().at(-1) ?? null;

const HIT_COLS = [
  { key: 'name', label: 'Player' },
  { key: 'pos', label: 'Pos', opt: true },
  { key: 'cls', label: 'Class', opt: true },
  { key: 'g', label: 'G', num: true, opt: true, gsep: true },
  { key: 'ab', label: 'AB', num: true, opt: true },
  { key: 'avg', label: 'AVG', num: true, gsep: true },
  { key: 'obp', label: 'OBP', num: true },
  { key: 'slg', label: 'SLG', num: true },
  { key: 'ops', label: 'OPS', num: true },
  { key: 'hr', label: 'HR', num: true, gsep: true },
  { key: 'rbi', label: 'RBI', num: true },
  { key: 'sb', label: 'SB', num: true },
  { key: 'pct', label: 'OPS Percentile', num: true, gsep: true, defaultSort: true },
];
const PIT_COLS = [
  { key: 'name', label: 'Player' },
  { key: 'pos', label: 'Pos', opt: true },
  { key: 'cls', label: 'Class', opt: true },
  { key: 'g', label: 'G', num: true, opt: true, gsep: true },
  { key: 'gs', label: 'GS', num: true, opt: true },
  { key: 'ip', label: 'IP', num: true, gsep: true },
  { key: 'era', label: 'ERA', num: true },
  { key: 'whip', label: 'WHIP', num: true },
  { key: 'k', label: 'K', num: true, gsep: true },
  { key: 'bb', label: 'BB', num: true },
  { key: 'sv', label: 'SV', num: true },
  { key: 'pct', label: 'ERA Percentile', num: true, gsep: true, defaultSort: true },
];
---
<div class="card shell">
  <div class="toolbar">
    <span class="ttl">Player statistics</span>
    <div class="tabs seg" role="tablist" aria-label="Player type">
      <button class="tab active" data-target="hitters" type="button" role="tab" id="tab-hitters"
        aria-selected="true" aria-controls="hitters" tabindex="0">Hitters</button>
      <button class="tab" data-target="pitchers" type="button" role="tab" id="tab-pitchers"
        aria-selected="false" aria-controls="pitchers" tabindex="-1">Pitchers</button>
    </div>
    <div class="filters">
      <input type="search" id="player-search" placeholder="Find a player or team…"
        aria-label="Filter players by name or team" autocomplete="off" />
      <select id="league-filter" aria-label="Filter by league">
        <option value="">All Leagues</option>
        {leagues.map((l) => <option value={l.key}>{l.name}</option>)}
      </select>
      <span class="count" id="result-count" aria-live="polite"></span>
      {statsThrough && <span class="stamp">Stats through {fmtDate(statsThrough)}</span>}
    </div>
  </div>

  <div class="panel" id="hitters" role="tabpanel" aria-labelledby="tab-hitters" tabindex="0">
  {hittersAll.length === 0 ? (
    <p class="none">No GT hitters with summer stats yet.</p>
  ) : (
    <table data-sortable data-side="hitters">
      <thead>
        <tr>
          {HIT_COLS.map((c) => (
            <th
              data-key={c.key}
              data-numeric={c.num ? '' : undefined}
              data-dir={c.defaultSort ? 'desc' : undefined}
              aria-sort={c.defaultSort ? 'descending' : undefined}
              scope="col"
              class:list={[{ opt: c.opt, gsep: c.gsep }]}
            >
              <button type="button" aria-label={`Sort by ${c.label}`}>{c.label}</button>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {hitters.map((p) => {
          const c = p.hitting!.counting;
          const r = p.hitting!.rates;
          const pct = sliderPct(p, 'hitting', 'ops');
          const prov = provProps(p);
          return (
            <tr data-league={p.summer.leagueKey} data-q={searchKey(p)}>
              <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={40} variant="bust" incoming={isIncoming(p)} incomingTitle={provenanceLabel(p)} /><span class="who"><span class="pname">{p.name} {prov && <ProvenanceTag {...prov} />} <span class="mchip"><PercentileChip percentile={pct} metric="OPS" /></span></span><span class="pteam">{p.summer.team}{leagueAbbrev(p) && <>{' · '}<abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></>}<span class="denom"> · {c.ab} AB</span></span></span></a></td>
              <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
              <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
              <td data-v={c.g} class="opt gsep">{c.g}</td>
              <td data-v={c.ab} class="opt">{c.ab}</td>
              <td data-v={r.avg ?? '—'} class="gsep">{fmtRate3(r.avg)}</td>
              <td data-v={r.obp ?? '—'}>{fmtRate3(r.obp)}</td>
              <td data-v={r.slg ?? '—'}>{fmtRate3(r.slg)}</td>
              <td data-v={r.ops ?? '—'} class="key">{fmtRate3(r.ops)}</td>
              <td data-v={c.hr} class="gsep">{c.hr}</td>
              <td data-v={c.rbi}>{c.rbi}</td>
              <td data-v={c.sb}>{c.sb}</td>
              <td data-v={pct ?? '—'} class="gsep"><PercentileBar percentile={pct} metric="OPS" /></td>
            </tr>
          );
        })}
      </tbody>
      <tbody class="empty-band" hidden>
        <tr><td colspan="13">
          <span class="empty-msg"></span>
          <button type="button" class="switch-tab" hidden></button>
          <button type="button" class="clear-filters">Clear filters</button>
        </td></tr>
      </tbody>
      {hittersSub.length > 0 && (
        <tbody class="subq">
          <tr class="subhead"><td colspan="13">Below qualifying threshold</td></tr>
          {hittersSub.map((p) => {
            const c = p.hitting!.counting;
            const r = p.hitting!.rates;
            const pct = sliderPct(p, 'hitting', 'ops');
            const prov = provProps(p);
            return (
              <tr data-league={p.summer.leagueKey} data-q={searchKey(p)}>
                <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={40} variant="bust" incoming={isIncoming(p)} incomingTitle={provenanceLabel(p)} /><span class="who"><span class="pname">{p.name} {prov && <ProvenanceTag {...prov} />} <span class="mchip"><PercentileChip percentile={pct} metric="OPS" muted /></span></span><span class="pteam">{p.summer.team}{leagueAbbrev(p) && <>{' · '}<abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></>}<span class="denom"> · {c.ab} AB</span></span></span></a></td>
                <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
                <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
                <td data-v={c.g} class="opt gsep">{c.g}</td>
                <td data-v={c.ab} class="opt">{c.ab}</td>
                <td data-v={r.avg ?? '—'} class="gsep">{fmtRate3(r.avg)}</td>
                <td data-v={r.obp ?? '—'}>{fmtRate3(r.obp)}</td>
                <td data-v={r.slg ?? '—'}>{fmtRate3(r.slg)}</td>
                <td data-v={r.ops ?? '—'} class="key">{fmtRate3(r.ops)}</td>
                <td data-v={c.hr} class="gsep">{c.hr}</td>
                <td data-v={c.rbi}>{c.rbi}</td>
                <td data-v={c.sb}>{c.sb}</td>
                <td data-v={pct ?? '—'} class="gsep"><PercentileBar percentile={pct} metric="OPS" muted /></td>
              </tr>
            );
          })}
        </tbody>
      )}
    </table>
  )}
  </div>

  <div class="panel" id="pitchers" role="tabpanel" aria-labelledby="tab-pitchers" tabindex="0" hidden>
  {pitchersAll.length === 0 ? (
    <p class="none">No GT pitchers with summer stats yet.</p>
  ) : (
    <table data-sortable data-side="pitchers">
      <thead>
        <tr>
          {PIT_COLS.map((c) => (
            <th
              data-key={c.key}
              data-numeric={c.num ? '' : undefined}
              data-dir={c.defaultSort ? 'desc' : undefined}
              aria-sort={c.defaultSort ? 'descending' : undefined}
              scope="col"
              class:list={[{ opt: c.opt, gsep: c.gsep }]}
            >
              <button type="button" aria-label={`Sort by ${c.label}`}>{c.label}</button>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {pitchers.map((p) => {
          const c = p.pitching!.counting;
          const r = p.pitching!.rates;
          const pct = sliderPct(p, 'pitching', 'era');
          const prov = provProps(p);
          return (
            <tr data-league={p.summer.leagueKey} data-q={searchKey(p)}>
              <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={40} variant="bust" incoming={isIncoming(p)} incomingTitle={provenanceLabel(p)} /><span class="who"><span class="pname">{p.name} {prov && <ProvenanceTag {...prov} />} <span class="mchip"><PercentileChip percentile={pct} metric="ERA" /></span></span><span class="pteam">{p.summer.team}{leagueAbbrev(p) && <>{' · '}<abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></>}<span class="denom"> · {c.ip} IP</span></span></span></a></td>
              <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
              <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
              <td data-v={c.g} class="opt gsep">{c.g}</td>
              <td data-v={c.gs} class="opt">{c.gs}</td>
              <td data-v={c.ip} class="gsep">{c.ip}</td>
              <td data-v={r.era ?? '—'} class="key">{fmtEra(r.era)}</td>
              <td data-v={r.whip ?? '—'}>{fmtEra(r.whip)}</td>
              <td data-v={c.k} class="gsep">{c.k}</td>
              <td data-v={c.bb}>{c.bb}</td>
              <td data-v={c.sv}>{c.sv}</td>
              <td data-v={pct ?? '—'} class="gsep"><PercentileBar percentile={pct} metric="ERA" /></td>
            </tr>
          );
        })}
      </tbody>
      <tbody class="empty-band" hidden>
        <tr><td colspan="12">
          <span class="empty-msg"></span>
          <button type="button" class="switch-tab" hidden></button>
          <button type="button" class="clear-filters">Clear filters</button>
        </td></tr>
      </tbody>
      {pitchersSub.length > 0 && (
        <tbody class="subq">
          <tr class="subhead"><td colspan="12">Below qualifying threshold</td></tr>
          {pitchersSub.map((p) => {
            const c = p.pitching!.counting;
            const r = p.pitching!.rates;
            const pct = sliderPct(p, 'pitching', 'era');
            const prov = provProps(p);
            return (
              <tr data-league={p.summer.leagueKey} data-q={searchKey(p)}>
                <td data-v={p.name}><a href={`/players/${p.slug}`}><Headshot name={p.name} photo={p.photo} size={40} variant="bust" incoming={isIncoming(p)} incomingTitle={provenanceLabel(p)} /><span class="who"><span class="pname">{p.name} {prov && <ProvenanceTag {...prov} />} <span class="mchip"><PercentileChip percentile={pct} metric="ERA" muted /></span></span><span class="pteam">{p.summer.team}{leagueAbbrev(p) && <>{' · '}<abbr title={leagueName(p)}>{leagueAbbrev(p)}</abbr></>}<span class="denom"> · {c.ip} IP</span></span></span></a></td>
                <td data-v={p.position || '—'} class="opt">{p.position || '—'}</td>
                <td data-v={p.classYear || '—'} class="opt">{p.classYear || '—'}</td>
                <td data-v={c.g} class="opt gsep">{c.g}</td>
                <td data-v={c.gs} class="opt">{c.gs}</td>
                <td data-v={c.ip} class="gsep">{c.ip}</td>
                <td data-v={r.era ?? '—'} class="key">{fmtEra(r.era)}</td>
                <td data-v={r.whip ?? '—'}>{fmtEra(r.whip)}</td>
                <td data-v={c.k} class="gsep">{c.k}</td>
                <td data-v={c.bb}>{c.bb}</td>
                <td data-v={c.sv}>{c.sv}</td>
                <td data-v={pct ?? '—'} class="gsep"><PercentileBar percentile={pct} metric="ERA" muted /></td>
              </tr>
            );
          })}
        </tbody>
      )}
    </table>
  )}
  </div>

  <p class="tfoot">
    Percentiles rank each player against all hitters or pitchers in his league, 2026 season.
    Qualified: 2.0 PA (hitters) or 0.5 IP (pitchers) per team game — others sit below the threshold line.
    A + on the portrait marks players new to GT for 2027 — hover or focus it for where they're from · unmarked players were on GT's 2026 roster.
  </p>
  <p class="tfoot legend">
    {leagues.map((l, i) => (
      <span class="lg"><strong>{l.abbrev}</strong> {l.name}{i < leagues.length - 1 ? '' : ''}</span>
    ))}
  </p>
</div>

<script>
  import { compareCells } from '../lib/tableSort';
  import type { SortDir } from '../lib/tableSort';
  import { parseViewState, serializeViewState } from '../lib/viewState';
  import type { Tab, ViewState } from '../lib/viewState';

  const filter = document.getElementById('league-filter') as HTMLSelectElement;
  const search = document.getElementById('player-search') as HTMLInputElement;
  const countEl = document.getElementById('result-count');
  const tabs = [...document.querySelectorAll<HTMLButtonElement>('.tab')];

  const SIDE_LABEL: Record<Tab, [string, string]> = {
    hitters: ['hitter', 'hitters'],
    pitchers: ['pitcher', 'pitchers'],
  };

  function activeTab(): Tab {
    return document.querySelector<HTMLButtonElement>('.tab.active')?.dataset.target === 'pitchers'
      ? 'pitchers'
      : 'hitters';
  }

  function activateTab(tab: HTMLButtonElement) {
    tabs.forEach((t) => {
      const active = t === tab;
      t.classList.toggle('active', active);
      t.setAttribute('aria-selected', String(active));
      t.tabIndex = active ? 0 : -1;
    });
    document.getElementById('hitters')!.toggleAttribute('hidden', tab.dataset.target !== 'hitters');
    document.getElementById('pitchers')!.toggleAttribute('hidden', tab.dataset.target !== 'pitchers');
    applyFilters();
  }

  function rowsOf(side: Tab): HTMLTableRowElement[] {
    return [...document.querySelectorAll<HTMLTableRowElement>(`#${side} tr[data-league]`)];
  }

  function matches(row: HTMLTableRowElement, q: string): boolean {
    const leagueOk = !filter.value || row.dataset.league === filter.value;
    const nameOk = !q || (row.dataset.q ?? '').includes(q);
    return leagueOk && nameOk;
  }

  function applyFilters() {
    const q = search.value.trim().toLowerCase();
    const counts: Record<Tab, number> = { hitters: 0, pitchers: 0 };
    (['hitters', 'pitchers'] as Tab[]).forEach((side) => {
      rowsOf(side).forEach((row) => {
        const ok = matches(row, q);
        row.style.display = ok ? '' : 'none';
        if (ok) counts[side]++;
      });
      // hide the sub-threshold band header when the whole band is filtered out
      const sub = document.querySelector<HTMLElement>(`#${side} tbody.subq`);
      if (sub) {
        const anySub = [...sub.querySelectorAll<HTMLTableRowElement>('tr[data-league]')]
          .some((r) => r.style.display !== 'none');
        sub.querySelector<HTMLElement>('.subhead')!.style.display = anySub ? '' : 'none';
      }
    });

    const side = activeTab();
    const other: Tab = side === 'hitters' ? 'pitchers' : 'hitters';
    const filtered = Boolean(q || filter.value);
    if (countEl) {
      countEl.textContent = filtered ? `${counts[side]} shown` : '';
    }

    // empty band with the reason and a way out
    (['hitters', 'pitchers'] as Tab[]).forEach((s) => {
      const band = document.querySelector<HTMLElement>(`#${s} .empty-band`);
      if (!band) return;
      const show = filtered && counts[s] === 0;
      band.toggleAttribute('hidden', !show);
      if (!show) return;
      const o: Tab = s === 'hitters' ? 'pitchers' : 'hitters';
      const leagueText = filter.value ? ` in the ${filter.options[filter.selectedIndex].text}` : '';
      const qText = q ? ` match “${search.value.trim()}”` : '';
      band.querySelector('.empty-msg')!.textContent = `No ${SIDE_LABEL[s][1]}${leagueText}${qText}.`;
      const switcher = band.querySelector<HTMLButtonElement>('.switch-tab')!;
      if (counts[o] > 0) {
        const n = counts[o];
        switcher.textContent = `Show ${n} ${n === 1 ? SIDE_LABEL[o][0] : SIDE_LABEL[o][1]}`;
        switcher.hidden = false;
      } else {
        switcher.hidden = true;
      }
    });
  }

  function applySort(table: HTMLTableElement, th: HTMLTableCellElement, dir: SortDir) {
    const idx = th.cellIndex;
    table.querySelectorAll('th').forEach((h) => {
      delete h.dataset.dir;
      h.removeAttribute('aria-sort');
    });
    th.dataset.dir = dir;
    th.setAttribute('aria-sort', dir === 'asc' ? 'ascending' : 'descending');
    const numeric = th.hasAttribute('data-numeric');
    const body = table.tBodies[0]; // qualified band only; the threshold band stays pinned below
    [...body.rows]
      .sort((a, b) => compareCells(
        a.cells[idx].dataset.v ?? '', b.cells[idx].dataset.v ?? '', numeric, dir))
      .forEach((r) => body.appendChild(r));
  }

  function defaultSort(table: HTMLTableElement) {
    const pct = table.querySelector<HTMLTableCellElement>('th[data-key="pct"]');
    if (pct) applySort(table, pct, 'desc');
  }

  function currentState(): ViewState {
    const tab = activeTab();
    const sorted = document.querySelector<HTMLTableCellElement>(`#${tab} th[data-dir]`);
    // the server default (percentile desc) is not state worth carrying in URLs
    const isDefault = sorted?.dataset.key === 'pct' && sorted.dataset.dir === 'desc';
    return {
      tab,
      league: filter.value,
      sort: sorted && !isDefault
        ? { key: sorted.dataset.key!, dir: sorted.dataset.dir === 'desc' ? 'desc' : 'asc' }
        : null,
      q: search.value.trim(),
    };
  }

  function syncUrl() {
    const qs = serializeViewState(currentState());
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      activateTab(tab);
      syncUrl();
    });
  });
  // APG tabs pattern: arrow keys move and activate within the tablist
  document.querySelector('.tabs')?.addEventListener('keydown', (e) => {
    const key = (e as KeyboardEvent).key;
    if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(key)) return;
    e.preventDefault();
    const current = tabs.findIndex((t) => t.classList.contains('active'));
    let next = current;
    if (key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
    if (key === 'ArrowRight') next = (current + 1) % tabs.length;
    if (key === 'Home') next = 0;
    if (key === 'End') next = tabs.length - 1;
    tabs[next].focus();
    activateTab(tabs[next]);
    syncUrl();
  });

  filter.addEventListener('change', () => {
    applyFilters();
    syncUrl();
  });
  search.addEventListener('input', () => {
    applyFilters();
    syncUrl();
  });
  search.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      search.value = '';
      applyFilters();
      syncUrl();
    }
  });
  // '/' focuses search from anywhere outside a field
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLSelectElement)) {
      e.preventDefault();
      search.focus();
    }
  });

  document.querySelectorAll<HTMLElement>('.empty-band').forEach((band) => {
    band.querySelector('.clear-filters')?.addEventListener('click', () => {
      search.value = '';
      filter.value = '';
      applyFilters();
      syncUrl();
    });
    band.querySelector('.switch-tab')?.addEventListener('click', () => {
      const other = tabs.find((t) => !t.classList.contains('active'));
      if (other) {
        activateTab(other);
        syncUrl();
      }
    });
  });

  document.querySelectorAll<HTMLTableElement>('table[data-sortable]').forEach((table) => {
    table.querySelectorAll<HTMLTableCellElement>('th[data-key]').forEach((th) => {
      th.querySelector('button')?.addEventListener('click', () => {
        // tri-state: first click (numeric → best-first desc, text → asc),
        // second click flips, third returns to the default percentile order
        const numeric = th.hasAttribute('data-numeric');
        const first: SortDir = numeric ? 'desc' : 'asc';
        const cur = th.dataset.dir as SortDir | undefined;
        if (!cur) applySort(table, th, first);
        else if (cur === first) applySort(table, th, first === 'desc' ? 'asc' : 'desc');
        else defaultSort(table);
        syncUrl();
      });
    });
  });

  // Edge shadow on the sticky player column while the table is scrolled.
  document.querySelectorAll<HTMLElement>('[role="tabpanel"]').forEach((panel) => {
    const update = () => panel.toggleAttribute('data-scrolled', panel.scrollLeft > 2);
    panel.addEventListener('scroll', update, { passive: true });
    update();
  });

  // Restore view state carried in the URL (e.g. returning via browser back from a player page),
  // driving the same code paths the click/change handlers use. Unknown values are ignored.
  const restored = parseViewState(location.search);
  if (restored.tab === 'pitchers') {
    const btn = tabs.find((t) => t.dataset.target === 'pitchers');
    if (btn) activateTab(btn);
  }
  if (restored.league && [...filter.options].some((o) => o.value === restored.league)) {
    filter.value = restored.league;
  }
  if (restored.q) search.value = restored.q;
  if (restored.sort) {
    const table = document.querySelector<HTMLTableElement>(`#${restored.tab} table[data-sortable]`);
    const th = table?.querySelector<HTMLTableCellElement>(`th[data-key="${CSS.escape(restored.sort.key)}"]`);
    if (table && th) applySort(table, th, restored.sort.dir);
  }
  applyFilters();
</script>

