// Full-body action shots — no crop produces a recognizable face; the gold
// monogram reads better than a blur.
const NO_PHOTO = new Set(['kolby-martin', 'luke-nitkowski']);
const DEFAULTS = { circle: 'width:210.0%;left:-55.0%;top:0%', bust: 'width:125.0%;left:-12.5%;top:0%' };
const EXT = { circle: 'width:126%;left:-13%;top:-2%', bust: 'width:112%;left:-6%;top:0%' };

const local = photo?.startsWith('/') ?? false;
const base = local ? photo!.split('/').pop()!.replace(/\.(jpg|jpeg|png|webp)$/i, '') : '';
const usePhoto = photo && !(local && NO_PHOTO.has(base));
const MAP = variant === 'bust' ? BUST : CIRCLE;
const cropStyle = local ? (MAP[base] ?? DEFAULTS[variant]) : EXT[variant];
const frameStyle = variant === 'bust'
  ? `width:${size}px;height:${Math.round(size * 1.25)}px`
  : `width:${size}px;height:${size}px`;
---
{usePhoto ? (
  <span class={`shot frame ${variant}`} style={frameStyle}>
    <img class="ph" src={photo} alt={name} style={cropStyle} />
  </span>
) : (
  <span
    class={`shot initials ${variant}`}
    style={`${frameStyle};font-size:${Math.round(size * (variant === 'bust' ? 0.3 : 0.34))}px`}
  >
    {initials}
  </span>
)}

<style>
  .shot {
    flex-shrink: 0;
    border: 2px solid var(--gold-light);
    background: linear-gradient(180deg, var(--gold), var(--gold-deep));
  }
  .circle { border-radius: 50%; }
  .bust { border-radius: 9px; }
  .frame {
    position: relative;
    display: inline-block;
    overflow: hidden;
  }
  .ph {
    position: absolute;
    height: auto;
  }
  .initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--navy-dark);
    font-weight: 800;
    /* flat gold: the gradient's deep end put navy-dark at 4.2:1 — below AA */
    background: var(--gold);
  }
</style>
