---
interface Props {
  name: string;
  photo: string | null;
  size: number;
  /** circle = identity chip in dense rows; bust = 4:5 portrait card for
      visual surfaces (score cards, field, heroes). */
  variant?: 'circle' | 'bust';
}
const { name, photo, size, variant = 'circle' } = Astro.props;
const initials = name.split(' ').map((w) => w[0]).slice(0, 2).join('');

// Framing is face-detection-derived per photo (OpenCV face boxes → hat-top-
// to-chin viewports), regenerated by the crop tooling and verified against
// rendered contact sheets. Spec: top of hat = top of frame. Values are
// proportional, so they hold at every size and survive pipeline re-downloads.
const CIRCLE: Record<string, string> = {
