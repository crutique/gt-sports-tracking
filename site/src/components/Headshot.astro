---
interface Props {
  name: string;
  photo: string | null;
  size: number;
}
const { name, photo, size } = Astro.props;
const initials = name.split(' ').map((w) => w[0]).slice(0, 2).join('');

// Head-only framing, calibrated per photo (sources vary: GT roster shots,
// Perfect Game torso shots, other schools' portraits). Values were verified
// against a rendered contact sheet of every file — see the crop simulation
// in the elevation session. Proportional, so they hold at every size and
// survive pipeline re-downloads. Unknown local files get the GT-roster
// default; external MLB silos use the class-based fallback.
const CROPS: Record<string, string> = {
  'adam-mckelvey': 'width:184.0%;left:-42.0%;top:-5.7%',
  'brady-fox': 'width:200.0%;left:-50.0%;top:-25.2%',
  'brett-barfield': 'width:184.0%;left:-42.0%;top:-5.7%',
  'brett-slymen': 'width:245.0%;left:-72.5%;top:-24.1%',
  'caden-gaudette': 'width:184.0%;left:-42.0%;top:-5.7%',
  'caden-spivey': 'width:184.0%;left:-42.0%;top:-5.7%',
  'caleb-daniel': 'width:184.0%;left:-42.0%;top:-5.7%',
  'carson-ballard': 'width:184.0%;left:-42.0%;top:-5.7%',
  'coleman-lewis': 'width:184.0%;left:-42.0%;top:-5.7%',
  'cooper-blauser': 'width:200.0%;left:-50.0%;top:-12.5%',
  'cooper-underwood': 'width:184.0%;left:-42.0%;top:-5.7%',
  'deion-cole': 'width:220.0%;left:-60.0%;top:-18.1%',
  'dimitri-angelakos': 'width:184.0%;left:-42.0%;top:-5.7%',
  'drew-rogers': 'width:184.0%;left:-42.0%;top:-5.7%',
  'dylan-loy': 'width:184.0%;left:-42.0%;top:-5.7%',
  'eli-stephens': 'width:200.0%;left:-50.0%;top:-16.6%',
  'ezekiel-lara': 'width:245.0%;left:-72.5%;top:-24.1%',
  'holden-pantier': 'width:200.0%;left:-50.0%;top:-24.9%',
  'isaiah-galason': 'width:245.0%;left:-72.5%;top:-24.1%',
  'jack-richerson': 'width:245.0%;left:-72.5%;top:-24.1%',
  'jackson-blakely': 'width:184.0%;left:-42.0%;top:-5.7%',
  'jackson-morgan': 'width:175.0%;left:-37.5%;top:-5.7%',
  'jake-lankie': 'width:184.0%;left:-42.0%;top:-5.7%',
  'jamie-vicens': 'width:184.0%;left:-42.0%;top:-5.7%',
  'jayden-stroman': 'width:200.0%;left:-50.0%;top:-20.2%',
  'jordan-lodise': 'width:200.0%;left:-50.0%;top:-20.2%',
  'josh-gunther': 'width:200.0%;left:-50.0%;top:-19.9%',
  'judson-hartwell': 'width:184.0%;left:-42.0%;top:-5.7%',
  'justin-shadek': 'width:184.0%;left:-42.0%;top:-5.7%',
  'kayden-campbell': 'width:184.0%;left:-42.0%;top:-5.7%',
  'kent-schmidt': 'width:184.0%;left:-42.0%;top:-5.7%',
  'logan-keilen': 'width:200.0%;left:-50.0%;top:-25.0%',
  'michael-nottleman': 'width:245.0%;left:-72.5%;top:-24.1%',
  'nathanael-coupet': 'width:184.0%;left:-42.0%;top:-5.7%',
  'patrick-walsh': 'width:155.0%;left:-27.5%;top:-4.3%',
  'reid-gainous': 'width:245.0%;left:-72.5%;top:-24.1%',
  'riley-hasenstab': 'width:184.0%;left:-42.0%;top:-5.7%',
  'ryan-zuckerman': 'width:184.0%;left:-42.0%;top:-5.7%',
  'tyler-guerin': 'width:184.0%;left:-42.0%;top:-8.2%',
  'will-baker': 'width:184.0%;left:-42.0%;top:-5.7%',
};
// Full-body action shots — no crop produces a recognizable face; the gold
// monogram reads better than a blur.
const NO_PHOTO = new Set(['kolby-martin', 'luke-nitkowski', 'ryan-engle']);
const GT_DEFAULT = 'width:184.0%;left:-42.0%;top:-5.7%';

const local = photo?.startsWith('/') ?? false;
const base = local ? photo!.split('/').pop()!.replace(/\.(jpg|jpeg|png|webp)$/i, '') : '';
const usePhoto = photo && !(local && NO_PHOTO.has(base));
const cropStyle = local ? (CROPS[base] ?? GT_DEFAULT) : null;
---
{usePhoto ? (
  <span class="shot frame" style={`width:${size}px;height:${size}px`}>
    <img
      class={`ph ${cropStyle ? '' : 'ext'}`}
      src={photo}
      alt={name}
      style={cropStyle}
    />
  </span>
) : (
  <span class="shot initials"
    style={`width:${size}px;height:${size}px;font-size:${Math.round(size * 0.34)}px`}>
    {initials}
  </span>
)}

<style>
  .shot {
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid var(--gold-light);
    background: linear-gradient(180deg, var(--gold), var(--gold-deep));
  }
  .frame {
    position: relative;
    display: inline-block;
    overflow: hidden;
  }
  .ph {
    position: absolute;
    height: auto;
  }
  /* MLB draft silos: head center ≈ (50%, 34%), framed tighter than roster shots */
  .ph.ext {
    width: 148%;
    left: -24%;
    top: -12%;
  }
  .initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--navy-dark);
    font-weight: 800;
  }
</style>
