---
// The class-money band: what GT's draftees actually signed for, one segment
// per signing (hover/focus names it), with MLB's slot total as a labeled
// reference — not a denominator. No clamp, no impossible fraction. After the
// deadline the band reads as the final ledger line.
import { fmtMoney, fmtMoneyCompact, poolSummary } from '../lib/draft';
import type { DraftPlayer } from '../lib/draft';

interface Props {
  players: DraftPlayer[];
  /** Signing period still open (isDeadlinePending at build time). */
  pending: boolean;
}
const { players, pending } = Astro.props;
const s = poolSummary(players);
const drafted = players.length;
const arrived = players.filter((p) => p.gtRole === 'signee' && p.status === 'did_not_sign').length;

const segs = players
  .filter((p) => (p.status === 'signed' || p.status === 'signed_udfa') && p.bonus != null)
  .sort((a, b) => (b.bonus ?? 0) - (a.bonus ?? 0))
  .map((p, i) => ({
    id: `dc-${p.personId ?? p.slug ?? i}`,
    name: p.name,
    bonus: p.bonus as number,
    tone: i % 2 === 0 ? 't1' : 't2',
    pct: ((p.bonus as number) / Math.max(s.signedKnown, 1)) * 100,
  }));
---
{s.signedKnown > 0 && (
  <section class="pool" aria-label="Draft class signing money">
    <div class="top">
      <span class="money">
        <strong>{fmtMoneyCompact(s.signedKnown)}</strong> committed across {s.signedCount} signings
      </span>
      <span class="mode">
        {pending
          ? `Signing period open through July 27`
          : `Final · signing period closed July 27`}
      </span>
    </div>
    <div class="bar" role="group" aria-label={`${fmtMoneyCompact(s.signedKnown)} committed; each segment is one player's bonus`}>
      {segs.map((g) => (
        <a class={`seg ${g.tone}`} href={`#${g.id}`} style={`width:${g.pct.toFixed(2)}%`}
          aria-label={`${g.name}, ${fmtMoney(g.bonus)}`}>
          <span class="stip" role="tooltip">{g.name} · {fmtMoney(g.bonus)}</span>
        </a>
      ))}
    </div>
    <div class="bottom">
      <span>{s.signedCount} of {drafted} drafted Jackets signed</span>
      {s.unsignedCount > 0 && <span>· {s.unsignedCount} unsigned</span>}
      {arrived > 0 && <span>· {arrived} arrived on campus</span>}
      {s.unreportedCount > 0 && <span>· {s.unreportedCount} signed, terms not yet reported</span>}
      {s.slotPool > 0 && (
        <span class="slotref">MLB slot value of GT's picks: {fmtMoneyCompact(s.slotPool)}</span>
      )}
    </div>
  </section>
)}

<style>
  .pool {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-bright) 100%);
    /* inset bar follows the rounded corners; a border-top would not */
    box-shadow: inset 0 3px 0 var(--gold);
    border-radius: 8px;
    padding: 16px 20px 18px;
    margin: 0 0 16px;
    color: var(--on-navy);
  }
  .top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .money { font-size: 14px; color: var(--on-navy-mut); }
  .money strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 34px;
    color: var(--on-navy);
    letter-spacing: 0.01em;
    margin-right: 2px;
  }
  .mode {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gold-light);
  }
  .bar {
    display: flex;
    height: 14px;
    border-radius: 7px;
    overflow: visible;
    background: rgba(255, 255, 255, 0.14);
  }
  .seg {
    position: relative;
    display: block;
    height: 100%;
    min-width: 3px; /* the $500 senior sign stays hoverable; the ladder below
                       carries the exact lengths */
  }
  .seg.t1 { background: var(--gold); }
  .seg.t2 { background: var(--gold-deep); }
  .seg:first-child { border-radius: 7px 0 0 7px; }
  .seg:last-child { border-radius: 0 7px 7px 0; }
  .seg:hover, .seg:focus-visible { outline: 2px solid var(--card); outline-offset: 1px; z-index: 2; }
  .stip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    background: var(--navy-dark);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--on-navy);
    font-size: 12px;
    font-weight: 600;
    padding: 5px 9px;
    border-radius: 7px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 5;
  }
  .seg:hover .stip, .seg:focus-visible .stip { opacity: 1; visibility: visible; }
  .bottom {
    margin-top: 9px;
    font-size: 12px;
    color: var(--on-navy-mut);
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: baseline;
  }
  .slotref { margin-left: auto; color: var(--on-navy-faint); }
  @media (prefers-reduced-motion: no-preference) {
    .stip { transition: opacity var(--t-fast) var(--ease-out); }
  }
  @media (max-width: 560px) {
    .slotref { margin-left: 0; width: 100%; }
  }
</style>
