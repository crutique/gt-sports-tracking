---
import Headshot from './Headshot.astro';
import { getDisplayablePlayers, getGamelog } from '../lib/data';
import type { HitterGame, PitcherGame, Player } from '../lib/data';
import { hitterGameScore, pitcherGameScore } from '../lib/stats';
import { fmtDate, outsToIp } from '../lib/format';

// The broadcast bottom-line: every GT performance from a given night streams
// across one row like an ESPN score ticker, loudest first — nobody gets
// crowned. The date is stated plainly (never claimed as "last night") and
// older nights are a click away. Skips itself entirely when no games exist.
// The continuous scroll is the site's one sanctioned ambient motion: it IS
// the score-bug identity. It pauses on hover/focus so its cards stay clickable,
// and collapses to a static, hand-scrollable strip under reduced motion.

interface Stat {
  v: string;
  l: string;
  hot?: boolean;
}

interface Card {
  slug: string;
  short: string;
  name: string;
  photo: string | null;
  team: string;
  opp: string;
  stats: Stat[];
  score: number;
  big: boolean;
}

const DAYS_SHOWN = 14;

function hitterCard(p: Player, g: HitterGame): Card {
  const stats: Stat[] = [{ v: `${g.h}-${g.ab}`, l: 'H-AB', hot: g.h >= 3 }];
  if (g.hr) stats.push({ v: String(g.hr), l: 'HR', hot: true });
  if (g.rbi) stats.push({ v: String(g.rbi), l: 'RBI' });
  if (g.sb) stats.push({ v: String(g.sb), l: 'SB', hot: g.sb >= 2 });
  if (g.bb >= 2) stats.push({ v: String(g.bb), l: 'BB' });
  if (g.r >= 2) stats.push({ v: String(g.r), l: 'R' });
  return {
    slug: p.slug,
    short: p.name.split(' ').slice(-1)[0].toUpperCase(),
    name: p.name,
    photo: p.photo,
    team: p.summer.team ?? '',
    opp: g.opponent,
    stats: stats.slice(0, 4),
    score: hitterGameScore(g),
    big: g.hr >= 1 || g.h >= 3 || g.sb >= 3,
  };
}

function pitcherCard(p: Player, g: PitcherGame): Card {
  const stats: Stat[] = [
    { v: outsToIp(g.ip_outs), l: 'IP' },
    { v: String(g.er), l: 'ER', hot: g.er === 0 && g.ip_outs >= 9 },
    { v: String(g.k), l: 'K', hot: g.k >= 7 },
  ];
  if (g.dec) stats.push({ v: g.dec, l: 'DEC' });
  return {
    slug: p.slug,
    short: p.name.split(' ').slice(-1)[0].toUpperCase(),
    name: p.name,
    photo: p.photo,
    team: p.summer.team ?? '',
    opp: g.opponent,
    stats,
    score: pitcherGameScore(g),
    big: g.k >= 7 || (g.er === 0 && g.ip_outs >= 12),
  };
}

const players = getDisplayablePlayers();
const byDate = new Map<string, Card[]>();
for (const p of players) {
  const side = p.pitching && !p.hitting ? 'pitching' : 'hitting';
  for (const g of getGamelog(p.slug)) {
    const card = side === 'hitting'
      ? hitterCard(p, g as HitterGame)
      : pitcherCard(p, g as PitcherGame);
    byDate.set(g.date, [...(byDate.get(g.date) ?? []), card]);
  }
}
const dates = [...byDate.keys()].sort().reverse().slice(0, DAYS_SHOWN);
for (const d of dates) byDate.get(d)!.sort((a, b) => b.score - a.score);
---
{dates.length > 0 && (
  <section class="panel" aria-label="Recent GT performances by date">
    <div class="bar">
      <p class="kick">Recent summer league games</p>
      <div class="nav">
        <button type="button" id="rg-prev" aria-label="Earlier date">‹</button>
        <span class="date" id="rg-date">{fmtDate(dates[0])}</span>
        <button type="button" id="rg-next" aria-label="Later date" disabled>›</button>
      </div>
    </div>
    <div class="ticker">
      {dates.map((d, i) => (
        <div class="lane" data-date={d} data-label={fmtDate(d)} hidden={i !== 0}>
          <div class="track">
            <div class="seq">
              {byDate.get(d)!.map((c) => (
                <a class="score-card" href={`/players/${c.slug}`}>
                  <span class="head">
                    <Headshot name={c.name} photo={c.photo} size={42} variant="bust" />
                    <span class="pname">{c.short}</span>
                    <span class="who">
                      <span class="pteam">{c.team}</span>
                      <span class="popp">{c.opp}</span>
                    </span>
                  </span>
                  <span class="line">
                    {c.stats.map((s) => (
                      <span class={`stat ${s.hot ? 'hot' : ''}`}>
                        <span class="sv">{s.v}</span>
                        <span class="sl">{s.l}</span>
                      </span>
                    ))}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<script>
  const SPEED = 55; // px/sec — a comfortable broadcast reading pace
  const reduce = matchMedia('(prefers-reduced-motion: reduce)');
  const lanes = [...document.querySelectorAll<HTMLElement>('.lane[data-date]')];
  const prev = document.getElementById('rg-prev') as HTMLButtonElement | null;
  const next = document.getElementById('rg-next') as HTMLButtonElement | null;
  const label = document.getElementById('rg-date');
  let idx = 0; // 0 = newest

  // Deal enough duplicate sequences to cover the viewport plus one full set,
  // then scroll by exactly one set's width — the content repeats seamlessly.
  function initLane(lane: HTMLElement) {
    if (lane.dataset.ready) return;
    const track = lane.querySelector('.track') as HTMLElement;
    const seq = track.querySelector('.seq') as HTMLElement;
    const seqW = seq.getBoundingClientRect().width;
    const laneW = lane.getBoundingClientRect().width;
    // A single set already fits: show a short night (or one lone game) static
    // and centered instead of cloning it to crawl in place. Scroll only when the
    // cards genuinely overflow the row.
    const overflows = seqW > laneW + 8;
    lane.classList.toggle('fits', !reduce.matches && !overflows);
    if (!reduce.matches && overflows) {
      const copies = Math.max(2, Math.ceil((laneW + seqW) / seqW));
      for (let k = 1; k < copies; k++) {
        const clone = seq.cloneNode(true) as HTMLElement;
        clone.setAttribute('aria-hidden', 'true');
        clone.querySelectorAll('a').forEach((a) => { (a as HTMLElement).tabIndex = -1; });
        track.appendChild(clone);
      }
      track.style.setProperty('--shift', `${seqW}px`);
      track.style.animationDuration = `${seqW / SPEED}s`;
      track.classList.add('run');
    }
    lane.dataset.ready = '1';
  }

  function resetLane(lane: HTMLElement) {
    const track = lane.querySelector('.track') as HTMLElement;
    track.querySelectorAll('.seq[aria-hidden]').forEach((n) => n.remove());
    track.classList.remove('run');
    track.style.removeProperty('--shift');
    track.style.animationDuration = '';
    lane.classList.remove('fits');
    delete lane.dataset.ready;
  }

  function show(i: number) {
    idx = Math.max(0, Math.min(lanes.length - 1, i));
    lanes.forEach((lane, j) => lane.toggleAttribute('hidden', j !== idx));
    if (label) label.textContent = lanes[idx].dataset.label ?? '';
    if (next) next.disabled = idx === 0;
    if (prev) prev.disabled = idx === lanes.length - 1;
    initLane(lanes[idx]);
  }

  prev?.addEventListener('click', () => show(idx + 1));
  next?.addEventListener('click', () => show(idx - 1));

  // Re-deal the visible lane on resize so the loop stays gap-free at any width.
  let rid = 0;
  addEventListener('resize', () => {
    clearTimeout(rid);
    rid = window.setTimeout(() => { resetLane(lanes[idx]); initLane(lanes[idx]); }, 160);
  });
  reduce.addEventListener?.('change', () => { resetLane(lanes[idx]); initLane(lanes[idx]); });

  show(0);
</script>

<style>
  .bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin: 0 0 12px;
  }
  .kick {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-light);
  }
  .nav { display: flex; align-items: center; gap: 8px; }
  .nav button {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    color: var(--on-navy);
    font-size: 15px;
    line-height: 1;
    cursor: pointer;
  }
  .nav button:hover:not(:disabled) { border-color: var(--gold); }
  .nav button:disabled { opacity: 0.35; cursor: default; }
  .nav button:focus-visible { outline-color: var(--gold); }
  .date {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--on-navy);
    min-width: 58px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  /* The ticker window: one row, edges faded like a broadcast lower-third. */
  .ticker {
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 30px, #000 calc(100% - 30px), transparent 100%);
            mask-image: linear-gradient(90deg, transparent 0, #000 30px, #000 calc(100% - 30px), transparent 100%);
  }
  .lane { overflow: hidden; }
  .lane[hidden] { display: none; }
  /* Short night that fits without scrolling: center it, no crawl. */
  .lane:not([hidden]).fits { display: flex; justify-content: center; }
  .track { display: inline-flex; flex-wrap: nowrap; will-change: transform; }
  .track.run {
    animation-name: ticker;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    /* duration set inline from measured width, so speed is constant */
  }
  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-1 * var(--shift))); }
  }
  /* pause so a hovered/focused card can be read and clicked */
  .ticker:hover .track.run,
  .track.run:focus-within { animation-play-state: paused; }
  .seq { display: inline-flex; flex-wrap: nowrap; flex: 0 0 auto; }

  .score-card {
    display: flex;
    flex-direction: column;
    gap: 9px;
    flex: 0 0 auto;
    width: 278px;
    padding: 11px 15px;
    border-right: 1px solid rgba(179, 163, 105, 0.22);
  }
  /* Header row: portrait, last name, then team/opponent stacked at the right. */
  .head { display: flex; align-items: center; gap: 10px; }
  .score-card:hover { text-decoration: none; }
  .score-card:hover .pname { color: var(--gold-light); }
  /* Standouts aren't stripe-marked — loudest-first ordering and the gold "hot"
     stat numbers already surface them, the way a real ticker stays uniform. */
  .who { display: flex; flex-direction: column; flex: 1; min-width: 0; line-height: 1.2; text-align: right; }
  .pname {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0.02em;
    color: var(--on-navy);
    white-space: nowrap;
    flex: 0 0 auto;
  }
  .pteam { font-size: 11px; color: var(--on-navy-mut); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .popp { font-size: 11px; color: var(--on-navy-faint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  /* Stats span the full card width beneath the header, split into equal cells. */
  .line {
    display: flex;
    gap: 4px;
    width: 100%;
    padding-top: 9px;
    border-top: 1px solid rgba(179, 163, 105, 0.22);
  }
  .stat { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 0; }
  .sv {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 21px;
    line-height: 1.05;
    color: var(--on-navy);
    font-variant-numeric: tabular-nums;
  }
  .stat.hot .sv { color: var(--gold-light); }
  .sl {
    margin-top: 1px;
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--on-navy-faint);
  }

  @media (max-width: 560px) {
    /* phones read ~one card at a time */
    .score-card { width: 80vw; max-width: 300px; }
  }
  @media (prefers-reduced-motion: reduce) {
    /* no auto-scroll: the row becomes a hand-scrollable strip */
    .lane { overflow-x: auto; scrollbar-width: thin; }
    .track { animation: none !important; }
  }
  @media (prefers-reduced-motion: no-preference) {
    .pname { transition: color var(--t-fast) var(--ease-out); }
    .nav button { transition: border-color var(--t-fast) var(--ease-out); }
  }
</style>
