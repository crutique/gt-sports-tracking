---
// Tabs serve two distinct jobs, so they're grouped by purpose: the spring
// roster (how the 2027 team is taking shape) and the summer-league following
// (how the guys are doing right now). Roster leads — it's the core audience tie.
const groups = [
  {
    label: 'Roster',
    links: [
      { href: '/', label: 'Outlook' },
      { href: '/draft', label: 'Draft' },
    ],
  },
  {
    label: 'Summer 2026',
    links: [
      { href: '/stats', label: 'Stats' },
      { href: '/leagues', label: 'By League' },
    ],
  },
];
const current = Astro.url.pathname;
function isCurrent(href: string): boolean {
  // Outlook is home; Stats owns the player deep-dives it links out to.
  if (href === '/') return current === '/';
  if (href === '/stats') return current.startsWith('/stats') || current.startsWith('/players');
  return current.startsWith(href);
}
---
<nav>
  <div class="wrap bar">
    <a class="brand" href="/">BASEBALL TRACKING <span>GT</span></a>
    <div class="links">
      {groups.map((g, i) => (
        <>
          {i > 0 && <span class="vr" aria-hidden="true"></span>}
          <div class="grp" role="group" aria-label={g.label}>
            <span class="glabel" aria-hidden="true">{g.label}</span>
            <div class="gtabs">
              {g.links.map((l) => (
                <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
              ))}
            </div>
          </div>
        </>
      ))}
    </div>
  </div>
</nav>

<style>
  nav {
    background: var(--navy);
    border-top: 3px solid var(--gold);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap; /* fixed height made wrapped links spill over the page */
    min-height: 52px;
    padding-top: 6px;
    padding-bottom: 6px;
    row-gap: 4px;
  }
  .brand {
    color: var(--on-navy);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 21px;
    letter-spacing: 0.04em;
  }
  .brand span { color: var(--gold); }
  .brand:hover { text-decoration: none; color: var(--gold-light); }

  /* Two purpose groups, each under a quiet eyebrow, split by a hairline. */
  .links { display: flex; align-items: stretch; flex-wrap: wrap; row-gap: 4px; }
  .grp { display: flex; flex-direction: column; justify-content: center; gap: 3px; }
  .glabel {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    line-height: 1;
    color: var(--on-navy-faint);
  }
  .gtabs { display: flex; gap: 16px; }
  .gtabs a {
    color: var(--on-navy-mut);
    font-size: 13px;
    font-weight: 600;
    padding: 2px 1px;
    border-bottom: 2px solid transparent;
    white-space: nowrap; /* labels never break mid-phrase */
  }
  .gtabs a:hover { color: var(--on-navy); text-decoration: none; }
  .gtabs a[aria-current='page'] {
    color: var(--on-navy);
    border-bottom-color: var(--gold);
  }
  .vr { width: 1px; align-self: stretch; background: rgba(255, 255, 255, 0.16); margin: 0 16px; }

  @media (max-width: 420px) {
    .brand { font-size: 18px; }
    .gtabs { gap: 12px; }
    .vr { margin: 0 11px; }
  }
</style>
