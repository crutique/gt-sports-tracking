---
const links = [
  { href: '/', label: 'Players' },
  { href: '/outlook', label: '2027 Outlook' },
  { href: '/draft', label: 'Draft' },
  { href: '/leagues', label: 'Leagues' },
];
const current = Astro.url.pathname;
function isCurrent(href: string): boolean {
  return href === '/' ? current === '/' : current.startsWith(href);
}
---
<nav>
  <div class="wrap bar">
    <a class="brand" href="/">GT SUMMER <span>TRACKER</span></a>
    <div class="links">
      {links.map((l) => (
        <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  nav {
    background: var(--navy);
    border-top: 3px solid var(--gold);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
  }
  .brand {
    color: var(--on-navy);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 21px;
    letter-spacing: 0.04em;
  }
  .brand span { color: var(--gold); }
  .brand:hover { text-decoration: none; color: var(--gold-light); }
  .links a {
    color: var(--on-navy-mut);
    font-size: 13px;
    font-weight: 600;
    margin-left: 18px;
    padding: 4px 2px;
    border-bottom: 2px solid transparent;
  }
  .links a:hover { color: var(--on-navy); text-decoration: none; }
  .links a[aria-current='page'] {
    color: var(--on-navy);
    border-bottom-color: var(--gold);
  }
</style>
