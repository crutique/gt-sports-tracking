---
import type { League, Player } from '../lib/data';
import { isSampleLeague } from '../lib/data';
import Headshot from './Headshot.astro';
import PercentileChip from './PercentileChip.astro';

interface Props {
  player: Player;
  league: League | undefined;
}
const { player, league } = Astro.props;

const meta = [player.position, player.classYear].filter(Boolean).join(' · ');

let context = '';
if (player.hitting) {
  context = `${player.hitting.counting.g} G · ${player.hitting.counting.ab} AB`;
} else if (player.pitching) {
  context = `${player.pitching.counting.g} G · ${player.pitching.counting.ip} IP`;
}

// The hero states the player's level visually: headline percentile as a chip.
const side = player.hitting ? 'hitting' : player.pitching ? 'pitching' : null;
const heroPct = side && !isSampleLeague(player.summer.leagueKey)
  ? player[side]?.sliders?.find((s) => s.metric === (side === 'hitting' ? 'ops' : 'era'))?.percentile ?? null
  : null;
const pctLabel = side === 'hitting' ? 'OPS %ile' : 'ERA %ile';
---
<header class="hero">
  <Headshot name={player.name} photo={player.photo} size={92} variant="bust" />
  <div class="who">
    <div class="row">
      <h1>{player.name}</h1>
      <span class="meta">{meta}</span>
    </div>
    <div class="row team-row">
      {player.summer.team && <span class="team">{player.summer.team}</span>}
      {league && <span class="pill">{league.name}</span>}
      {!player.summer.team && <span class="team">No summer assignment confirmed yet</span>}
    </div>
  </div>
  <div class="context">
    <div class="season">2026 Summer</div>
    {context && <div class="line">{context}</div>}
    {heroPct !== null && (
      <div class="pct-row">
        <PercentileChip percentile={heroPct} />
        <span class="pct-label">{pctLabel}</span>
      </div>
    )}
  </div>
</header>

<style>
  .hero {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, var(--navy-bright) 100%);
    border-top: 3px solid var(--gold);
    border-radius: 8px 8px 0 0;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .who { flex: 1; min-width: 0; }
  .row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  h1 {
    margin: 0;
    color: var(--on-navy);
    font-size: 36px;
    letter-spacing: 0.01em;
  }
  .meta {
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .team-row { margin-top: 6px; align-items: center; }
  .team { color: var(--on-navy-mut); font-size: 13px; }
  .pill {
    background: var(--gold);
    color: var(--navy-dark);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 12px;
    padding: 2px 10px;
  }
  .context { text-align: right; flex-shrink: 0; }
  .season {
    color: var(--on-navy-faint);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .line { color: var(--on-navy-mut); font-size: 13px; margin-top: 2px; }
  .pct-row {
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
  }
  .pct-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--on-navy-faint);
  }
  @media (max-width: 560px) {
    .pct-row { justify-content: flex-start; }
  }
  @media (max-width: 560px) {
    .hero { flex-wrap: wrap; }
    .context { text-align: left; }
  }
</style>
