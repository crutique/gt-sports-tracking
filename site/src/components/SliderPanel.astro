---
import PercentileSlider from './PercentileSlider.astro';
import type { StatBlock } from '../lib/data';

interface Props {
  block: StatBlock;
  leagueName: string;
  side: 'hitting' | 'pitching';
  dual: boolean;
}
const { block, leagueName, side, dual } = Astro.props;
const title = dual
  ? `${leagueName} Percentile Rankings — ${side === 'hitting' ? 'Batting' : 'Pitching'}`
  : `${leagueName} Percentile Rankings`;
---
<section>
  <h2 class="section-title">{title}</h2>
  {block.sliders ? (
    <>
      {block.sliders.map((s) => <PercentileSlider slider={s} qualified={block.qualified !== false} />)}
      {block.qualified === false && (
        <p class="unqual-note">
          <span class="swatch" aria-hidden="true"></span>
          Unqualified sample size
        </p>
      )}
    </>
  ) : (
    <p class="no-pct">
      Full {leagueName} statistics aren't in our feed, so percentiles aren't available for this line.
    </p>
  )}
</section>

<style>
  .no-pct { color: var(--text-mut); font-size: 13px; }
  section { margin-bottom: 8px; }
  .unqual-note {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 4px 0 0;
    font-size: 12px;
    color: var(--text-mut);
  }
  .swatch {
    width: 26px;
    height: 11px;
    border-radius: 3px;
    flex-shrink: 0;
    background-color: var(--pct-mid);
    background-image: repeating-linear-gradient(-45deg, hsla(0, 0%, 100%, 0.6) 0 4px, hsla(0, 0%, 100%, 0) 4px 9px);
  }
</style>
