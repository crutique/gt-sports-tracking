---
import { getDisplayablePlayers, getGamelog, getLeagueByKey } from '../lib/data';
import type { HitterGame, Player } from '../lib/data';
import { lastDaysLine } from '../lib/stats';
import { fmtRate3 } from '../lib/format';
import { percentileColor } from '../lib/colors';

// The signature display: every GT player as a gold dot on one infield arc,
// positioned by their league percentile (OPS for hitters, ERA for pitchers).
// Position is the encoding; the arc is the field's own geometry doing IA work.

interface Dot {
  slug: string;
  name: string;
  short: string;
  pct: number;
  side: 'hitting' | 'pitching';
  league: string;
  x: number;
  y: number;
  r: number;
}

function headline(p: Player): { pct: number; side: 'hitting' | 'pitching' } | null {
  const side = p.hitting ? 'hitting' : 'pitching';
  const metric = side === 'hitting' ? 'ops' : 'era';
  const pct = p[side]?.sliders?.find((s) => s.metric === metric)?.percentile ?? null;
  return pct === null ? null : { pct, side };
}

const W = 960;
const H = 288;
const CX = W / 2;
const CY = 264;
const R = 224;
const rad = (deg: number) => (deg * Math.PI) / 180;
const angleOf = (pct: number) => 180 - 1.8 * pct;
const posAt = (pct: number, radius: number) => ({
  x: CX + radius * Math.cos(rad(angleOf(pct))),
  y: CY - radius * Math.sin(rad(angleOf(pct))),
});

const players = getDisplayablePlayers()
  .map((p) => {
    const h = headline(p);
    return h ? { p, ...h } : null;
  })
  .filter((x): x is { p: Player; pct: number; side: 'hitting' | 'pitching' } => x !== null)
  .sort((a, b) => a.pct - b.pct);

// Greedy lane packing: dots closer than ~5° on the arc step inward a lane,
// so ties read as a cluster instead of an overlap.
const MIN_GAP_DEG = 5;
const LANE_STEP = 20;
const laneLast: number[] = [];
const dots: Dot[] = players.map(({ p, pct, side }) => {
  const theta = angleOf(pct);
  let lane = 0;
  while (lane < laneLast.length && Math.abs(laneLast[lane] - theta) < MIN_GAP_DEG) lane++;
  laneLast[lane] = theta;
  const { x, y } = posAt(pct, R - lane * LANE_STEP);
  const last = p.name.split(' ').slice(-1)[0];
  return {
    slug: p.slug,
    name: p.name,
    short: last.toUpperCase(),
    pct,
    side,
    league: getLeagueByKey(p.summer.leagueKey)?.abbrev ?? '',
    x,
    y,
    r: 7,
  };
});

const leader = dots.length ? dots[dots.length - 1] : null;
if (leader) leader.r = 9;

const arcStart = posAt(0, R);
const arcEnd = posAt(100, R);
const tickPcts = [0, 25, 50, 75, 100];

// Annotation layer — the strip says what matters instead of only showing it.
const hitters = getDisplayablePlayers().filter((p) => p.hitting);
const latestDate = hitters
  .flatMap((p) => getGamelog(p.slug).map((g) => g.date))
  .sort()
  .at(-1);
const HOT_MIN_AB = 8;
const hottest = latestDate
  ? hitters
      .map((p) => ({ p, line: lastDaysLine(getGamelog(p.slug) as HitterGame[], 7, latestDate) }))
      .filter((x) => x.line.ops !== null && x.line.ab >= HOT_MIN_AB)
      .sort((a, b) => (b.line.ops ?? 0) - (a.line.ops ?? 0))[0] ?? null
  : null;

const leaderPlayer = leader ? players.find((x) => x.p.slug === leader.slug)?.p : null;
const leaderLeague = leaderPlayer ? getLeagueByKey(leaderPlayer.summer.leagueKey) : null;
---
{dots.length >= 3 && (
  <section class="glance card">
    <h2 class="section-title">The Summer at a Glance</h2>
    <svg
      viewBox={`0 0 ${W} ${H}`}
      role="img"
      aria-label={`Every GT player positioned by league percentile, 0 to 100.${leader ? ` ${leader.name} leads at the ${leader.pct}th percentile.` : ''}`}
    >
      <defs>
        <linearGradient id="arc-ramp" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="var(--pct-low)" />
          <stop offset="0.5" stop-color="var(--pct-mid)" />
          <stop offset="1" stop-color="var(--pct-high)" />
        </linearGradient>
      </defs>
      <path
        d={`M ${arcStart.x} ${arcStart.y} A ${R} ${R} 0 0 1 ${arcEnd.x} ${arcEnd.y}`}
        class="arc"
      />
      {tickPcts.map((t) => {
        const o = posAt(t, R + 7);
        const i = posAt(t, R - 7);
        return <line x1={o.x} y1={o.y} x2={i.x} y2={i.y} class="tick" />;
      })}
      {dots.map((d) => (
        <a href={`/players/${d.slug}`} aria-label={`${d.name}, ${d.pct}th percentile ${d.side === 'hitting' ? 'OPS' : 'ERA'} in the ${d.league}`}>
          <title>{`${d.name} — ${d.pct}th pct ${d.side === 'hitting' ? 'OPS' : 'ERA'} (${d.league})`}</title>
          <circle cx={d.x} cy={d.y} r="16" fill="transparent" />
          <circle cx={d.x} cy={d.y} r={d.r} class={`dot ${d.side === 'pitching' ? 'arm' : ''}`} />
        </a>
      ))}
      {leader && (
        <text x={leader.x} y={leader.y - 16} text-anchor="middle" class="leader-label">
          {leader.short} · {leader.pct}
        </text>
      )}
      <text x={arcStart.x - 4} y={CY + 18} text-anchor="start" class="axis">0 · cold</text>
      <text x={CX} y={CY - R - 16} text-anchor="middle" class="axis">50 · league average</text>
      <text x={arcEnd.x + 4} y={CY + 18} text-anchor="end" class="axis">100 · elite</text>
    </svg>
    <div class="caption">
      {leader && leaderLeague && (
        <span>
          <a href={`/players/${leader.slug}`}><strong>{leader.name}</strong></a> leads GT —
          {' '}<span class="pct-word" style={`color:${percentileColor(leader.pct)}`}>{leader.pct}th percentile</span>
          {' '}{leader.side === 'hitting' ? 'OPS' : 'ERA'} in the {leaderLeague.name}
        </span>
      )}
      {hottest && hottest.p.slug !== leader?.slug && (
        <span class="hot-note">
          · hottest week: <a href={`/players/${hottest.p.slug}`}><strong>{hottest.p.name}</strong></a>
          {' '}({fmtRate3(hottest.line.ops)} OPS over 7 days)
        </span>
      )}
      <span class="legend" aria-hidden="true">● hitters &nbsp;○ pitchers</span>
    </div>
  </section>
)}

<style>
  .glance { padding: 18px 20px 14px; margin: 0 0 18px; }
  svg { display: block; width: 100%; height: auto; }
  .arc {
    fill: none;
    stroke: url(#arc-ramp);
    stroke-width: 9;
    stroke-linecap: round;
    opacity: 0.9;
  }
  .tick { stroke: var(--line); stroke-width: 2; }
  .dot {
    fill: var(--gold);
    stroke: var(--navy-dark);
    stroke-width: 2;
  }
  .dot.arm { fill: var(--card); stroke: var(--gold-deep); stroke-width: 2.5; }
  a:focus-visible .dot { stroke: var(--navy); stroke-width: 4; }
  .leader-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    fill: var(--navy);
    paint-order: stroke;
    stroke: var(--card);
    stroke-width: 4px;
    stroke-linejoin: round;
  }
  .axis { font-size: 12px; fill: var(--text-mut); }
  .caption {
    margin-top: 10px;
    font-size: 13px;
    color: var(--text);
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: baseline;
  }
  .pct-word { font-weight: 800; }
  .legend { margin-left: auto; font-size: 11px; color: var(--text-mut); white-space: nowrap; }
  @media (prefers-reduced-motion: no-preference) {
    .dot { transition: stroke-width var(--t-fast) var(--ease-out); }
    a:hover .dot { stroke-width: 4; }
  }
  @media (max-width: 560px) {
    .glance { padding: 12px 12px 10px; }
    .leader-label { font-size: 22px; }
    .axis { font-size: 15px; }
  }
</style>
