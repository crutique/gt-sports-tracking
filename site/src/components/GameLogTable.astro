---
import { fmtDate, outsToIp } from '../lib/format';
import type { GameLogEntry, HitterGame, PitcherGame } from '../lib/data';

interface Props {
  entries: GameLogEntry[];
  side: 'hitting' | 'pitching';
}
const { entries, side } = Astro.props;

const headers = side === 'hitting'
  ? ['Date', 'Opponent', 'AB', 'R', 'H', '2B', '3B', 'HR', 'RBI', 'BB', 'K', 'SB']
  : ['Date', 'Opponent', 'IP', 'H', 'R', 'ER', 'BB', 'K', 'HR', 'Dec'];

interface Cell {
  v: string | number;
  cls?: string;
}

// Big games get quiet emphasis: multi-hit and HR games for hitters,
// big strikeout days for pitchers. Weight only — the table stays a table.
function cells(e: GameLogEntry): Cell[] {
  if (side === 'hitting') {
    const g = e as HitterGame;
    return [
      { v: fmtDate(g.date) }, { v: g.opponent }, { v: g.ab }, { v: g.r },
      { v: g.h, cls: g.h >= 2 ? 'big' : undefined },
      { v: g.d }, { v: g.t },
      { v: g.hr, cls: g.hr >= 1 ? 'big' : undefined },
      { v: g.rbi }, { v: g.bb }, { v: g.k }, { v: g.sb },
    ];
  }
  const g = e as PitcherGame;
  return [
    { v: fmtDate(g.date) }, { v: g.opponent }, { v: outsToIp(g.ip_outs) },
    { v: g.h }, { v: g.r }, { v: g.er }, { v: g.bb },
    { v: g.k, cls: g.k >= 7 ? 'big' : undefined },
    { v: g.hr }, { v: g.dec || '—' },
  ];
}
---
<section>
  <h2 class="section-title">Game Log</h2>
  {entries.length === 0 ? (
    <p class="none">No games recorded yet.</p>
  ) : (
    <div class="scroller" tabindex="0" role="region"
      aria-label={`${side === 'hitting' ? 'Batting' : 'Pitching'} game log — scrolls horizontally`}>
      <table>
        <thead>
          <tr>{headers.map((h) => <th scope="col">{h}</th>)}</tr>
        </thead>
        <tbody>
          {entries.map((e) => <tr>{cells(e).map((c) => <td class={c.cls}>{c.v}</td>)}</tr>)}
        </tbody>
      </table>
    </div>
  )}
</section>

<script>
  document.querySelectorAll<HTMLElement>('.scroller').forEach((s) => {
    const update = () => s.toggleAttribute('data-scrolled', s.scrollLeft > 2);
    s.addEventListener('scroll', update, { passive: true });
    update();
  });
</script>

<style>
  section { padding: 16px 20px 20px; }
  .none { color: var(--text-mut); font-size: 13px; }
  .scroller { overflow-x: auto; position: relative; }
  .scroller:focus-visible { outline: 2px solid var(--navy); outline-offset: 2px; border-radius: 6px; }
  /* edge shadow while more columns wait off-screen (mirrors the roster table) */
  .scroller[data-scrolled] table { box-shadow: -8px 0 8px -8px rgba(0, 0, 0, 0.28) inset; }
  table { background: var(--card); border-radius: 6px; font-size: 12.5px; }
  th {
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-mut);
    font-weight: 600;
    padding: 6px 8px;
    border-bottom: 2px solid var(--gold);
  }
  td { padding: 6px 8px; border-bottom: 1px solid var(--line-soft); white-space: nowrap; }
  .big { font-weight: 700; }
  tr:last-child td { border-bottom: none; }
  th:nth-child(n + 3), td:nth-child(n + 3) { text-align: center; }
</style>
