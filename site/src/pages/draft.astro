---
import DraftPool from '../components/DraftPool.astro';
import Headshot from '../components/Headshot.astro';
import Base from '../layouts/Base.astro';
import { fmtMoney, fmtMoneyDelta, getDraft, STATUS_LABEL } from '../lib/draft';
import { getPlayer } from '../lib/data';

const draft = getDraft();
---
<Base title="2026 MLB Draft — GT Summer Tracker">
  <h1>2026 MLB Draft — Georgia Tech</h1>
  <p class="sub">
    GT's draft class: who signed, for how much, and who's headed (back) to campus.
    {draft.asOf && <span class="asof">Updated {draft.asOf}</span>}
  </p>

  {draft.players.length > 0 && <DraftPool players={draft.players} />}

  {draft.players.length === 0 && <p class="empty">Draft data loads with the next nightly refresh.</p>}

  {draft.players.length > 0 && (
    <div class="card table-card">
      <table>
        <thead>
          <tr>
            <th scope="col">Pick</th>
            <th scope="col">Player</th>
            <th scope="col">Drafted by</th>
            <th scope="col" class="r">Slot value</th>
            <th scope="col" class="r">Bonus</th>
            <th scope="col">Status</th>
          </tr>
        </thead>
        <tbody>
          {draft.players.map((p) => {
            const reg = p.slug ? getPlayer(p.slug) : undefined;
            return (
              <tr>
                <td class="pick">{p.pick != null ? `R${p.round} · #${p.pick}` : '—'}</td>
                <td class="player">
                  <div class="pwrap">
                    <Headshot name={p.name} photo={reg?.photo ?? p.headshot ?? null} size={34} />
                    <span class="pcell">
                      {p.slug ? <a href={`/players/${p.slug}`}>{p.name}</a> : <span class="pname">{p.name}</span>}
                      <span class="role">{p.gtRole === 'signee' ? 'Incoming signee' : 'GT 2026'}</span>
                      {p.note && <span class="pnote">{p.note}</span>}
                    </span>
                  </div>
                </td>
                <td class="team">{p.team ?? '—'}</td>
                <td class="num money">{fmtMoney(p.slot)}</td>
                <td class="num">
                  <span class="bonus-cell">
                    <span class="money">
                      {p.bonus == null && (p.status === 'signed' || p.status === 'signed_udfa') && p.reportedSourceUrl
                        ? <a class="pending" href={p.reportedSourceUrl} rel="noopener">terms not yet reported</a>
                        : (p.bonusSource === 'reported' && p.reportedSourceUrl)
                        ? <a class="valuelink" href={p.reportedSourceUrl} rel="noopener"
                             title="Reported figure — click for source" aria-label={`${fmtMoney(p.bonus)}, reported, source link`}>{fmtMoney(p.bonus)}</a>
                        : (p.bonusSource === 'unverified' && p.unverifiedSourceUrl)
                        ? <a class="valuelink" href={p.unverifiedSourceUrl} rel="noopener">{fmtMoney(p.bonus)}</a>
                        : fmtMoney(p.bonus)}
                    </span>
                    {p.bonus != null && p.slot != null && (
                      <span class={`delta ${p.bonus > p.slot ? 'over' : p.bonus < p.slot ? 'under' : 'even'}`}>
                        {p.bonus === p.slot ? 'at slot' : `${fmtMoneyDelta(p.bonus, p.slot)} vs slot`}
                      </span>
                    )}
                    {p.bonusSource === 'unverified' && p.unverifiedSourceUrl &&
                      <a class="unverified" href={p.unverifiedSourceUrl} rel="noopener">unverified</a>}
                  </span>
                </td>
                <td><span class={`chip ${p.status}`}>{STATUS_LABEL[p.status]}</span></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  {draft.udfa.length > 0 && (
    <section class="card udfa">
      <h2 class="section-title">Undrafted free agents</h2>
      <ul>
        {draft.udfa.map((p) => (
          <li>
            <Headshot name={p.name} photo={p.headshot} size={26} />
            <span class="ucell">
              <span class="uname">{p.name}</span>
              <span class="usub">{p.team}{p.signedDate ? ` · signed ${p.signedDate}` : ''}</span>
            </span>
            {p.reportedSourceUrl && <a class="usrc" href={p.reportedSourceUrl} rel="noopener">source</a>}
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  h1 { margin: 0 0 2px; }
  .sub { margin: 0 0 18px; color: var(--text-mut); font-size: 14px; max-width: 65ch; }
  .asof { margin-left: 10px; font-size: 12px; }
  .empty { color: var(--text-mut); font-size: 14px; }

  .table-card { overflow-x: auto; }
  table { font-size: 13px; }
  th {
    text-align: left;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-mut);
    font-weight: 700;
    padding: 10px 8px;
    border-bottom: 2px solid var(--gold);
    white-space: nowrap;
  }
  th.r { text-align: right; }
  td { padding: 10px 8px; border-bottom: 1px solid var(--line-soft); vertical-align: middle; }
  th:first-child, td:first-child { padding-left: 14px; }
  th:last-child, td:last-child { padding-right: 14px; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--line-soft); }

  .pick {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--text-mut);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .player { min-width: 230px; }
  .pwrap { display: flex; align-items: center; gap: 10px; }
  .pcell { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .pcell a, .pname { font-weight: 700; }
  .role { font-size: 11px; color: var(--text-mut); }
  .pnote { font-size: 12px; color: var(--text-mut); font-style: italic; max-width: 340px; white-space: normal; }
  .team { white-space: nowrap; }
  .num { text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
  .money {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--navy);
    font-variant-numeric: tabular-nums;
  }
  .bonus-cell { display: inline-flex; flex-direction: column; align-items: flex-end; line-height: 1.3; }
  .valuelink { text-decoration: underline dotted; color: inherit; }
  .pending { font-size: 11px; font-style: italic; color: var(--text-mut); text-decoration: underline dotted; }
  .unverified { margin-left: 6px; font-size: 11px; font-style: italic; color: var(--text-mut); text-decoration: underline dotted; }
  .delta { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-weight: 700; font-size: 11px; }
  .delta.over { color: var(--up); }
  .delta.under { color: var(--down); }
  .delta.even { color: var(--text-mut); font-weight: 400; font-style: italic; }
  .pick { color: var(--text-mut); }
  .chip { font-size: 12px; font-weight: 700; padding: 2px 8px; border-radius: 999px; white-space: nowrap; }
  .chip.signed, .chip.signed_udfa { background: var(--ok-bg); color: var(--ok-ink); }
  .chip.unsigned { background: var(--line-soft); color: var(--text-mut); }
  .chip.returning { background: var(--navy); color: var(--gold); }
  .chip.did_not_sign { background: var(--bad-bg); color: var(--bad-ink); }

  .udfa { margin-top: 14px; padding: 16px; }
  .udfa ul { list-style: none; margin: 0; padding: 0; }
  .udfa li {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 0;
    font-size: 13px;
    border-bottom: 1px dotted var(--line);
  }
  .udfa li:last-child { border-bottom: none; }
  .ucell { display: flex; flex-direction: column; line-height: 1.3; min-width: 0; }
  .uname { font-weight: 600; }
  .usub { font-size: 11px; color: var(--text-mut); }
  .usrc { margin-left: auto; font-size: 12px; }

  @media (prefers-reduced-motion: no-preference) {
    td { transition: background-color var(--t-fast) var(--ease-out); }
  }
</style>
