---
import Base from '../layouts/Base.astro';
import FieldDiagram from '../components/FieldDiagram.astro';
import Headshot from '../components/Headshot.astro';
import PercentileChip from '../components/PercentileChip.astro';
import ProvenanceTag from '../components/ProvenanceTag.astro';
import { DEADLINE_LABEL, getDraft, isDeadlinePending } from '../lib/draft';
import type { DraftPlayer } from '../lib/draft';
import { getLeagueByKey, getPlayers, isSampleLeague, provenanceLabel } from '../lib/data';
import type { Player } from '../lib/data';

// The second core question — "what does next spring look like?" — answered in
// counts and chips: who's back, who's arriving, who's in limbo until the
// signing deadline, who's gone pro. Numbers talk; words are labels.

const players = getPlayers();
const draft = getDraft();

const SIGNED: DraftPlayer['status'][] = ['signed', 'signed_udfa'];

const signeeSignedSlugs = new Set(
  draft.players
    .filter((p) => p.gtRole === 'signee' && SIGNED.includes(p.status) && p.slug)
    .map((p) => p.slug as string),
);
const signeeDraftedBySlug = new Map(
  draft.players
    .filter((p) => p.gtRole === 'signee' && p.slug)
    .map((p) => [p.slug as string, p]),
);

const returning = players.filter((p) => p.gtStatus === 'returning');
const transfers = players.filter((p) => p.gtStatus === 'transfer');
const freshmen = players.filter((p) => p.gtStatus === 'freshman');

const arriving = [
  ...transfers,
  ...freshmen.filter((p) => !signeeSignedSlugs.has(p.slug)),
];
// Arriving splits by how they get here: transfers vs. incoming recruits.
const arrivingByType = [
  { label: 'Transfers', players: arriving.filter((p) => p.gtStatus === 'transfer') },
  { label: 'Recruits', players: arriving.filter((p) => p.gtStatus === 'freshman') },
].filter((g) => g.players.length > 0);
const back = returning;
const draftReturners = draft.players.filter((p) => p.status === 'returning');

const limbo = draft.players.filter((p) => p.gtRole === 'departing' && p.status === 'unsigned');
const gone = [
  ...draft.players.filter((p) => p.gtRole === 'departing' && SIGNED.includes(p.status)),
  ...draft.udfa,
  ...draft.players.filter((p) => p.gtRole === 'signee' && SIGNED.includes(p.status)),
];

function summerPct(p: Player): number | null {
  if (isSampleLeague(p.summer.leagueKey)) return null;
  const side = p.hitting ? 'hitting' : p.pitching ? 'pitching' : null;
  if (!side) return null;
  const metric = side === 'hitting' ? 'ops' : 'era';
  return p[side]?.sliders?.find((s) => s.metric === metric)?.percentile ?? null;
}

const sortedBack = [...back].sort((a, b) => (summerPct(b) ?? -1) - (summerPct(a) ?? -1));
const anyLimbo = limbo.length > 0;

// Roster math: the projected 2027 roster against the House-settlement cap.
// 34 is the D-I baseball roster limit formally adopted June 2025; teams may
// exceed it only via designated student-athlete exemptions, so the overage
// reads as pressure, not a promise of exactly that many cuts.
const ROSTER_LIMIT = 34;
const ROSTER_LIMIT_URL =
  'https://www.ncaa.org/news/2025/6/23/media-center-di-board-of-directors-formally-adopts-changes-to-roster-limits.aspx';
const deadline = isDeadlinePending() ? DEADLINE_LABEL : null;
const unsignedArriving = arriving.filter((p) => signeeDraftedBySlug.get(p.slug)?.status === 'unsigned').length;
const projected = back.length + arriving.length;
const over = projected - ROSTER_LIMIT;
---
<Base title="Baseball Tracking GT — Georgia Tech baseball's 2027 roster"
  description="Who's back, who's arriving, and who's gone pro — Georgia Tech baseball's 2027 roster as the draft resolves.">
  <h1>2027 Roster Outlook</h1>

  <section class="card math"
    aria-label={`Roster math: ${back.length} returning plus ${arriving.length} arriving is ${projected} projected, against the ${ROSTER_LIMIT}-man roster limit${unsignedArriving > 0 && deadline ? `; ${unsignedArriving} unsigned until ${deadline}` : ''}`}>
    <div class="bar" aria-hidden="true">
      <span class="seg s-ret" style={`width:${(back.length / projected) * 100}%`}></span>
      <span class="seg s-arr" style={`width:${((arriving.length - unsignedArriving) / projected) * 100}%`}></span>
      {unsignedArriving > 0 && <span class="seg s-lim" style={`width:${(unsignedArriving / projected) * 100}%`}></span>}
      <span class="cap" style={`left:${(ROSTER_LIMIT / projected) * 100}%`}>
        <span class="cap-lab">limit {ROSTER_LIMIT}</span>
      </span>
    </div>
    <p class="math-labs">
      <span><i class="dot d-ret"></i><strong>{back.length}</strong> returning</span>
      <span><i class="dot d-arr"></i><strong>{arriving.length}</strong> arriving{unsignedArriving > 0 && deadline && (
        <span class="qual"> · {unsignedArriving} unsigned until {deadline}</span>
      )}</span>
      <span><strong>{projected}</strong> projected</span>
      <span class="over"><strong>{over > 0 ? `${over} over` : 'inside'}</strong>&nbsp;the&nbsp;<a
        href={ROSTER_LIMIT_URL} rel="noopener"
        title="34-man D-I baseball roster limit under the House settlement — teams may exceed it only via designated student-athlete exemptions">{ROSTER_LIMIT}-man limit ↗</a></span>
    </p>
  </section>

  <section class="card field-card">
    <div class="field-head">
      <h2 class="section-title">2027 roster by position</h2>
    </div>
    <FieldDiagram returning={back} arriving={arriving}
      undecided={arriving.filter((p) => signeeDraftedBySlug.get(p.slug)?.status === 'unsigned').map((p) => p.slug)} />
  </section>

  <div class="grid" id="roster-ledger">
    <section class="card col">
      <header>
        <span class="count">{back.length + draftReturners.length}</span>
        <h2 class="section-title">Returning</h2>
      </header>
      <p class="rcpt">Rating is percentile within each player's summer league — OPS for hitters and ERA for pitchers.</p>
      <ul>
        {sortedBack.map((p) => {
          const pct = summerPct(p);
          return (
            <li>
              <a href={`/players/${p.slug}`}>
                <Headshot name={p.name} photo={p.photo} size={26} variant="bust" />
                <span class="who">{p.name}<span class="sub">{p.position || '—'}{p.classYear ? ` · ${p.classYear}` : ''}</span></span>
                {pct !== null && <span class="tail"><PercentileChip percentile={pct} metric={`summer ${p.hitting ? 'OPS' : 'ERA'}`} muted /></span>}
              </a>
            </li>
          );
        })}
        {draftReturners.map((p) => (
          <li>
            <span class="row">
              <Headshot name={p.name} photo={p.headshot} size={26} variant="bust" />
              <span class="who">{p.name}<span class="sub">withdrew from draft</span></span>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="card col">
      <header>
        <span class="count">{arriving.length}</span>
        <h2 class="section-title">Arriving</h2>
        {unsignedArriving > 0 && deadline && (
          <span class="qual head-qual">{unsignedArriving} unsigned · {deadline}</span>
        )}
      </header>
      {arrivingByType.map((grp) => (
        <>
          <p class="subhead">{grp.label}</p>
          <ul>
            {grp.players.map((p) => {
              const d = signeeDraftedBySlug.get(p.slug);
              const limbo = d && d.status === 'unsigned';
              return (
                <li>
                  <a href={`/players/${p.slug}`}>
                    <Headshot name={p.name} photo={p.photo} size={26} variant="bust" incoming={!limbo}
                      incomingTitle={provenanceLabel(p)} />
                    <span class="who">{p.name}<span class="sub">{[p.position, p.classYear].filter(Boolean).join(' · ') || '—'}</span></span>
                    {limbo && (
                      <span class="tail">
                        <ProvenanceTag kind="drafted" draft={d.pick != null ? `R${d.round} by ${d.team}` : null} deadline={deadline} />
                      </span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </>
      ))}
    </section>

    {anyLimbo && (
      <section class="card col limbo">
        <header>
          <span class="count">{limbo.length}</span>
          <h2 class="section-title">Unsigned draftees · deadline Jul 27</h2>
        </header>
        <ul>
          {limbo.map((p) => (
            <li>
              <span class="row">
                <Headshot name={p.name} photo={p.headshot} size={26} variant="bust" />
                <span class="who">{p.name}<span class="sub">{p.pick != null ? `R${p.round} · #${p.pick}` : 'drafted'}{p.team ? ` · ${p.team}` : ''}</span></span>
                <span class="tail tag warn">unsigned</span>
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="card col">
      <header>
        <span class="count">{gone.length}</span>
        <h2 class="section-title">Signed pro</h2>
      </header>
      <ul>
        {gone.map((p) => (
          <li>
            <span class="row">
              <Headshot name={p.name} photo={p.headshot} size={26} variant="bust" />
              <span class="who">{p.name}<span class="sub">{p.team ?? '—'}{p.gtRole === 'signee' ? ' · signee' : ''}</span></span>
              <span class="tail tag">{p.status === 'signed_udfa' || !p.pick ? 'UDFA' : `R${p.round}`}</span>
            </span>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>

<style>
  /* tight vertical budget: park + section header + math strip share one screen */
  h1 { margin: -8px 0 10px; }

  /* Roster math: length does the talking — 19 + 21 = 40 against the 34 cap. */
  .math { padding: 18px 20px 10px; margin-bottom: 12px; }
  .bar {
    position: relative;
    display: flex;
    height: 14px;
  }
  .seg { display: block; height: 100%; }
  .s-ret { background: var(--gold); border-radius: 7px 0 0 7px; }
  .s-arr { background: var(--navy); }
  .s-lim { background: var(--warn-ink); border-radius: 0 7px 7px 0; }
  .cap {
    position: absolute;
    top: -5px;
    bottom: -5px;
    width: 0;
    border-left: 2px solid var(--text);
  }
  .cap-lab {
    position: absolute;
    bottom: calc(100% + 2px);
    left: 0;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
    white-space: nowrap;
  }
  .math-labs {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 20px;
    margin: 10px 0 0;
    font-size: 12.5px;
    color: var(--text-mut);
  }
  .math-labs strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    margin-right: 5px;
    vertical-align: -1px;
  }
  .d-ret { background: var(--gold); }
  .d-arr { background: var(--navy); }
  .qual { color: var(--warn-ink); font-weight: 600; }
  .over a { color: var(--text-mut); text-decoration: underline; }
  .over a:hover { color: var(--navy); }

  .field-card { padding: 12px 20px 14px; margin-bottom: 14px; }
  .field-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .field-head .section-title { flex: 1; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
    align-items: start;
  }
  .col { padding: 16px; }
  .col header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .count {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 44px;
    line-height: 1;
    color: var(--navy);
    font-variant-numeric: tabular-nums;
  }
  .col header .section-title { flex: 1; margin: 0; }
  .head-qual { font-size: 11px; white-space: nowrap; }
  .subhead {
    margin: 9px 0 1px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-mut);
  }
  ul + .subhead { margin-top: 10px; }
  .rcpt { margin: -4px 0 8px; font-size: 12px; color: var(--text-mut); max-width: 46ch; }
  .rcpt strong { color: var(--text); font-weight: 700; }
  .limbo .count { color: var(--warn-ink); }
  ul { list-style: none; margin: 0; padding: 0; }
  li a, .row {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 0;
    font-weight: 600;
    font-size: 13.5px;
    color: var(--text);
  }
  li a:hover { text-decoration: none; }
  li a:hover .who { color: var(--navy); text-decoration: underline; }
  .who { display: flex; flex-direction: column; min-width: 0; line-height: 1.25; }
  .sub { color: var(--text-mut); font-weight: 400; font-size: 11px; }
  .tail { margin-left: auto; flex-shrink: 0; }
  .tag {
    font-size: 11px; /* label floor */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text); /* --text-mut on --line-soft measured 4.3:1 — under AA */
    background: var(--line-soft);
    border-radius: 8px;
    padding: 2px 7px;
  }
  .tag.warn { color: var(--warn-ink); background: var(--warn-bg); }
</style>
