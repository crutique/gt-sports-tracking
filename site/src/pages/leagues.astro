---
import Headshot from '../components/Headshot.astro';
import Base from '../layouts/Base.astro';
import { getLeagues, getPlayer } from '../lib/data';

const leagues = getLeagues();
---
<Base title="Leagues — GT Summer Tracker">
  <h1>Leagues</h1>
  <p class="sub">Where GT players are spending the 2026 summer.</p>
  <div class="grid">
    {leagues.map((league) => (
      <section class="card league">
        <header>
          <h2>{league.name}</h2>
          <span class="count">{league.gtPlayers.length} GT player{league.gtPlayers.length === 1 ? '' : 's'}</span>
        </header>
        {league.platform === 'fixture' && <p class="sample">Sample data — live stats coming soon</p>}
        <ul>
          {league.gtPlayers.map((slug) => {
            const p = getPlayer(slug);
            return p ? (
              <li>
                <a href={`/players/${p.slug}`}>
                  <Headshot name={p.name} photo={p.photo} size={26} />
                  <span>{p.name}</span>
                  <span class="team">{p.summer.team}</span>
                </a>
              </li>
            ) : null;
          })}
        </ul>
        <a class="official" href={league.officialUrl} rel="noopener">Official {league.abbrev} site →</a>
      </section>
    ))}
  </div>
</Base>

<style>
  h1 { margin: 0 0 2px; font-size: 24px; }
  .sub { margin: 0 0 18px; color: var(--text-mut); font-size: 14px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 14px;
  }
  .league { padding: 16px; }
  .league header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid var(--gold);
    padding-bottom: 6px;
  }
  .league h2 { margin: 0; font-size: 16px; color: var(--navy); }
  .count { font-size: 12px; color: var(--text-mut); }
  .sample {
    margin: 8px 0 0;
    font-size: 11px;
    color: #92600a;
    background: #fdf3dd;
    border-radius: 5px;
    padding: 4px 8px;
    display: inline-block;
  }
  ul { list-style: none; margin: 10px 0; padding: 0; }
  li a {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 0;
    font-weight: 600;
    font-size: 14px;
  }
  .team { color: var(--text-mut); font-weight: 400; font-size: 12px; }
  .official { font-size: 12px; font-weight: 600; }
</style>
