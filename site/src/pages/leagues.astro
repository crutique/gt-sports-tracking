---
import Headshot from '../components/Headshot.astro';
import PercentileChip from '../components/PercentileChip.astro';
import Base from '../layouts/Base.astro';
import { getLeagues, getPlayer } from '../lib/data';
import type { Player } from '../lib/data';

const leagues = getLeagues();

function headlinePct(p: Player): number | null {
  const side = p.hitting ? 'hitting' : p.pitching ? 'pitching' : null;
  if (!side) return null;
  const metric = side === 'hitting' ? 'ops' : 'era';
  return p[side]?.sliders?.find((s) => s.metric === metric)?.percentile ?? null;
}

function medianPct(slugs: string[], platform: string): number | null {
  if (platform === 'fixture') return null; // fixture stats never feed a display
  const vals = slugs
    .map((s) => getPlayer(s))
    .map((p) => (p ? headlinePct(p) : null))
    .filter((v): v is number => v !== null)
    .sort((a, b) => a - b);
  if (vals.length === 0) return null;
  const mid = Math.floor(vals.length / 2);
  return vals.length % 2 ? vals[mid] : Math.round((vals[mid - 1] + vals[mid]) / 2);
}
---
<Base title="Leagues — GT Summer Tracker">
  <h1>Leagues</h1>
  <p class="sub">Where GT players are spending the 2026 summer.</p>
  <div class="grid">
    {leagues.map((league) => (
      <section class="card league">
        <header>
          <h2>{league.name}</h2>
          <span class="ab">{league.abbrev}</span>
        </header>
        <div class="meta">
          <span class="count">{league.gtPlayers.length} GT player{league.gtPlayers.length === 1 ? '' : 's'}</span>
          {medianPct(league.gtPlayers, league.platform) !== null && (
            <span class="med" title="Median percentile of GT players in this league">
              median <PercentileChip percentile={medianPct(league.gtPlayers, league.platform)} />
            </span>
          )}
        </div>
        {league.platform === 'fixture' && <p class="sample">Live stats feed coming soon — no numbers shown until they're real</p>}
        <ul>
          {league.gtPlayers.map((slug) => {
            const p = getPlayer(slug);
            if (!p) return null;
            const pct = league.platform === 'fixture' ? null : headlinePct(p);
            return (
              <li>
                <a href={`/players/${p.slug}`}>
                  <Headshot name={p.name} photo={p.photo} size={28} />
                  <span class="who">{p.name}<span class="team">{p.summer.team}</span></span>
                  {pct !== null && <span class="tail"><PercentileChip percentile={pct} /></span>}
                </a>
              </li>
            );
          })}
        </ul>
        <a class="official" href={league.officialUrl} rel="noopener">Official {league.abbrev} site →</a>
      </section>
    ))}
  </div>
</Base>

<style>
  h1 { margin: 0 0 2px; }
  .sub { margin: 0 0 18px; color: var(--text-mut); font-size: 14px; max-width: 65ch; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 14px;
    align-items: start;
  }
  .league { padding: 16px; }
  .league header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 2px solid var(--gold);
    padding-bottom: 6px;
  }
  .league h2 { margin: 0; font-size: 16px; color: var(--navy); }
  .ab {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--text-mut);
  }
  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: 8px;
    font-size: 12px;
    color: var(--text-mut);
  }
  .med { display: inline-flex; align-items: center; gap: 5px; }
  .sample {
    margin: 8px 0 0;
    font-size: 11px;
    color: var(--warn-ink);
    background: var(--warn-bg);
    border-radius: 5px;
    padding: 4px 8px;
    display: inline-block;
  }
  ul { list-style: none; margin: 10px 0; padding: 0; }
  li a {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 0;
    font-weight: 600;
    font-size: 13.5px;
    color: var(--text);
    border-bottom: 1px dotted var(--line);
  }
  li:last-child a { border-bottom: none; }
  li a:hover { text-decoration: none; }
  li a:hover .who { color: var(--navy); text-decoration: underline; }
  .who { display: flex; flex-direction: column; min-width: 0; line-height: 1.25; }
  .team { color: var(--text-mut); font-weight: 400; font-size: 11px; }
  .tail { margin-left: auto; flex-shrink: 0; }
  .official { display: inline-block; margin-top: 4px; font-size: 12px; font-weight: 600; }
</style>
