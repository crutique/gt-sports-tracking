---
import Base from '../layouts/Base.astro';
import HomeHero from '../components/HomeHero.astro';
import RosterTable from '../components/RosterTable.astro';
import { getAssignedPlayers, getLeagueByKey, getUnassignedPlayers, isSampleLeague } from '../lib/data';

const unassigned = getUnassignedPlayers();
const pending = unassigned.filter((p) => p.summer.status === 'unassigned' && p.gtStatus !== 'freshman');
const freshmen = unassigned.filter((p) => p.gtStatus === 'freshman');
const notPlaying = unassigned.filter((p) => p.summer.status === 'not_playing');
// Assigned but nothing displayable — no stats yet, or a fixture-only league
// feed (fake stats never render). Must not silently disappear from the page.
const awaiting = getAssignedPlayers().filter(
  (p) => (!p.hitting && !p.pitching) || isSampleLeague(p.summer.leagueKey),
);
---
<Base title="GT Summer Tracker — Georgia Tech baseball in the summer leagues">
  <HomeHero slot="bleed" />
  <h2 class="section-title roster-head">Player statistics</h2>
  <RosterTable />

  {awaiting.length > 0 && (
    <section class="quiet">
      <h2 class="section-title">Assigned — awaiting stats</h2>
      <p>
        {awaiting.map((p, i) => (
          <>
            <a href={`/players/${p.slug}`}>{p.name}</a>
            <span class="where"> ({p.summer.team}, {getLeagueByKey(p.summer.leagueKey)?.name})</span>
            {i < awaiting.length - 1 ? ' · ' : ''}
          </>
        ))}
      </p>
    </section>
  )}

  {pending.length > 0 && (
    <section class="quiet">
      <h2 class="section-title">No summer assignment yet</h2>
      <p>
        {pending.map((p, i) => (
          <>
            <a href={`/players/${p.slug}`}>{p.name}</a>{i < pending.length - 1 ? ' · ' : ''}
          </>
        ))}
      </p>
    </section>
  )}

  {freshmen.length > 0 && (
    <section class="quiet">
      <h2 class="section-title">Incoming Freshmen</h2>
      <p class="note">High school Class of 2026 signees — incoming freshmen typically don't play collegiate summer ball.</p>
      <p>
        {freshmen.map((p, i) => (
          <>
            <a href={`/players/${p.slug}`}>{p.name}</a>{i < freshmen.length - 1 ? ' · ' : ''}
          </>
        ))}
      </p>
    </section>
  )}

  {notPlaying.length > 0 && (
    <section class="quiet">
      <h2 class="section-title">Not playing this summer</h2>
      <p>
        {notPlaying.map((p, i) => (
          <>
            <a href={`/players/${p.slug}`}>{p.name}</a>{i < notPlaying.length - 1 ? ' · ' : ''}
          </>
        ))}
      </p>
    </section>
  )}
</Base>

<style>
  .roster-head { margin-bottom: 12px; }
  .quiet { margin-top: 26px; }
  .quiet p { font-size: 13px; line-height: 2; margin: 0; max-width: 72ch; }
  .where { color: var(--text-mut); }
  .note { font-size: 12px; color: var(--text-mut); margin: 0 0 4px; }
</style>
